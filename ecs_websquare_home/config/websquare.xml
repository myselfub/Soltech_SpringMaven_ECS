<?xml version="1.0" encoding="UTF-8"?>
<websquare>
	<default_encoding value="UTF-8" />
	<encodig value="UTF-8" />
	<dispatcher>
		<post>
			<encoding value="UTF-8"></encoding>
			<!-- <encoding value="ISO_8859_1"></encoding> -->
		</post>
	</dispatcher>
	<engineType value="6" etag="support" coverage="notsupport" deprecated="NONE" />
	<wqDefiner value="websquare.http.controller.grid.excel.read.UploadMultiSheet" />
	<upload>
		<support value="true" />
		<useFileUpload value="true" />
		<encoding value="UTF-8" />
		<baseDir value="C:/daonfile">
		<!-- <baseDir value="/was1/kes/kesfile"> -->
		</baseDir>
		<firstfilePostFix value="false" />
		<duplicatedFilePostFix value="yyyy-MM-dd(HH mm ss)" />
		<maxUploadSize value="2147483648" /> <!-- 2GB -->
		<allowedExtension>
			gif, jpg, doc, xls, ppt, pdf, txt, xlsx, png, pptx, xml, docx, hwp, shp, shx, dbf, dxf, dwg, ngi, vi, mp4, inp, 7Z, ALZ, BMP, EGG, GUL, HWX, INI, LSB, LSM, LSX, LZH, MHT, PEG, RAR, TIF, VSD, XLT, XPS, ZIP, enc, evl, kbid, rpt, inp, rtp, jpeg, tiff, xlsm, ttf
		</allowedExtension>
		<deniedExtension>
			exe, com, sh, html, htm, js, jsp, sh, dhtml, php, phtm, phar, cgi, pl, jsp, asp, inc
		</deniedExtension>
		<callback>
			<removeKeyPath value="true" />
		</callback>
		<uploadMode value="session" />
		<folderName value="tempupload" />
		<fileDefiner value="kw.scm.sc.file.service.impl.ComnUploadFileDefinerImpl"/>
		<decrypt value="" />
		<decryptTempDir value="" />
		<imgUpload>
			<baseDir value="C:/daonfile">
			<!-- <baseDir value="/was1/kes/kesfile"> -->
			</baseDir>
			<verifyHeader value="false" />
			<allowedExtension value="" />
			<deniedExtension value="" />
			<imageDefiner value="" />
		</imgUpload>
	</upload>
	<excel>
		<encoding value="UTF-8" /><!-- ISO_8859_1 / UTF8 -->
		<upload>
			<decrypt value="kw.fw.excel.ExcelUploadDecFasoo" tempDir="/daonfile/fasoo/tmp" />
			<!-- <decrypt value="kw.fw.excel.ExcelUploadDecFasoo" tempDir="/was1/kes/kesfile/fasoo/tmp" /> -->
			<dataXMLProvider value=""/>
			<dataConvertor value="" />
			<maxRowCount value="20000" />
			<maxCellCount value="100000" />
			<loadingMode value="POI" />
			<saxDecimal value="2" />
			<validExtension value="false" />
			<cellDataConvertor value="" />
			<applyExcelFormat value="" />
			<dataRefine value="" />
		</upload>
		<download>
			<encrypt value="kw.fw.excel.ExcelDownloadEncFasoo"/>
        	<dataXMLProvider value="kw.fw.util.WebsquareExcelDataConvertor"/>
			<encrypt value=""/>
			<dataXMLProvider value=""/>
			<dataConvertor value="" />
			<headerColor value="" />
			<bodyColor value="" />
			<footerColor value="" />
			<subtotalColor value="" />
			<maxRowCount value="20000" />
			<allowedExtension value="xls, xlsx, xlsm" />
			<rowAccessWindowSize value="200" />
			<tempDir value="" />
			<baseDir value="" />
			<dataTypeDate value="" />
			<keyMode value="random" preFix="SITE" />
			<userAgent value="" />
			<definer value="" />
		</download>
		<read>
			<displayType value="number" />
		</read>
	</excel>
	<csv>
		<encoding value="UTF-8" />
		<useBOM value="true" />
		<opencsv value="false" />
		<upload>
			<maxUploadSize value="1073741824" /> <!-- 1GB -->
			<decrypt value="" tempDir="/daonfile/fasoo/tmp" />
			<!-- <decrypt value="kw.fw.excel.ExcelUploadDecFasoo" tempDir="/was1/kes/kesfile/fasoo/tmp" /> -->
			<checkEncode value="false" />
		</upload>
		<download>
			<keyMode value="random" preFix="SITE" />
			<userAgent value="" />
			<dataConvertor value="" />
			<encrypt value="kw.fw.excel.ExcelDownloadEncFasoo" />
			<definer value="" />
		</download>
	</csv>

	<!--
		라이센스 정보를 볼 수 있는 IP 대역 설정
	-->
	<!--
	<licenseInfoView>
		<allowedIP value="192.168.* *" />
	</licenseInfoView>
	-->
	<!--
	1 : 기존 엔진 - 기본값
	2 : 기존 엔진(debug정보 제거)
	3 : 신규 엔진
	4 : 신규 엔진(debug정보 제거)
	직접 지정하는 경우 : w2xType

	etag
	support : etag값을 비교하여 일치하면 상태코드를 304로 반환 (기본값)
	notsupport : etag값 비교 지원 안함
	deprecated
		1이상의 정수, ALL, NONE를 입력할 수 있다.
		ALL이 입력된 경우 deprecated가 설정된 모든 함수를 사용할 수 없다.
		정수가 입력된 경우 정수보다 작거나 같은 버전으로 deprecated된 함수는 사용할 수 없다.
		소스에 있는 deprecated 버전보다 큰 값이 입력되어도 오류가 발생하지는 않는다.
		NONE가 입력된 경우 deprecated된 함수를 포함한 모든 함수를 사용할 수 있다.
		설정이 없는 경우 NONE와 동일하다.
		설정에 다른 값이 들어간 경우 NONE와 동일하다.
	-->

	<i18n>
		<baseDir value="/lang/" />
		<defaultLocale value="ko">
			<domain name="localhost" locale="kr" />
			<domain name="kes.[BASE_DOMAIN]" locale="kr" />
		</defaultLocale>
		<localeParam value="" />
		<storageType value="0" />
		<baseDir value="" />
		<baseUrl value="" />
		<cache value="false" />
		<keystorePath value="" />
		<keystoreType value="" />
		<keystoreaPass value="" />
		<xmlInfo storageType="" baseDir="" excludeList="" cache="false" autoReload="true">
			<web2fileCacheImpl value="websquare.i18n.impl.DefaultWeb2FileCacheImpl" />
		</xmlInfo>
		<messageInfo storageType="" baseDir="">
			<messageImpl value="websquare.i18n.impl.DefaultWeb2FileCacheImpl" />
		</messageInfo>
	</i18n>

	<adapter>
		<request>
			<convertType server="map" client="json" />
			<chartset value="UTF-8" />
		</request>
		<response>
			<immediateToStream value="true" />
			<convertType server="map" client="json" />
			<chartset value="UTF-8" />
			<qutation value="true" />
		</response>
		<xml>
			<valueNode use="false" />
		</xml>
		<extends>
			<autoConvertServerType value="true">
				<uri-pattern>
					<bean value="bean" />
					<map value="map" />
				</uri-pattern>
			</autoConvertServerType>
		</extends>
	</adapter>
