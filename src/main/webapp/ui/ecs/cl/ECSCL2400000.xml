			<w2:dataCollection baseNode="map">
				<w2:dataMap id="dmaSearchParam" baseNode="map">
					<w2:keyInfo>
						<w2:key id="strtDt" dataType="number" name="조회연도"></w2:key>
					</w2:keyInfo>
				</w2:dataMap>
				<w2:dataList id="dltAutoCondition1" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<w2:column id="clsCd" dataType="text" name="대분류 코드"></w2:column>
						<w2:column id="clsCdNm" dataType="text" name="대분류 이름"></w2:column>
						<w2:column id="cmmnCd" dataType="text" name="소분류 코드"></w2:column>
						<w2:column id="cmmnCdNm" dataType="text" name="소분류 이름"></w2:column>
						<w2:column id="upperCmmnCd" dataType="text" name="상위 소분류 코드1"></w2:column>
						<w2:column id="upperCmmnCdNm" dataType="text" name="상위 소분류 이름1"></w2:column>
						<w2:column id="upperCmmnCd2" dataType="text" name="상위 소분류 코드2"></w2:column>
						<w2:column id="upperCmmnCdNm2" dataType="text" name="상위 소분류 이름2"></w2:column>
						<w2:column id="upperCmmnCd3" dataType="text" name="상위 소분류 코드3"></w2:column>
						<w2:column id="upperCmmnCdNm3" dataType="text" name="상위 소분류 이름3"></w2:column>
