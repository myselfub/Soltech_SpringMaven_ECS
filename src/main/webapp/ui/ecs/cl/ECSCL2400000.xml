						<w2:column id="bassAmtMon02" dataType="number" name="월별 기본금(원) -2월"></w2:column>
						<w2:column id="bassAmtMon03" dataType="number" name="월별 기본금(원) -3월"></w2:column>
						<w2:column id="bassAmtMon04" dataType="number" name="월별 기본금(원) -4월"></w2:column>
						<w2:column id="bassAmtMon05" dataType="number" name="월별 기본금(원) -5월"></w2:column>
						<w2:column id="bassAmtMon06" dataType="number" name="월별 기본금(원) -6월"></w2:column>
						<w2:column id="bassAmtMon07" dataType="number" name="월별 기본금(원) -7월"></w2:column>
						<w2:column id="bassAmtMon08" dataType="number" name="월별 기본금(원) -8월"></w2:column>
						<w2:column id="bassAmtMon09" dataType="number" name="월별 기본금(원) -9월"></w2:column>
						<w2:column id="bassAmtMon10" dataType="number" name="월별 기본금(원) -10월"></w2:column>
						<w2:column id="bassAmtMon11" dataType="number" name="월별 기본금(원) -11월"></w2:column>
						<w2:column id="bassAmtMon12" dataType="number" name="월별 기본금(원) -12월"></w2:column>
						<w2:column id="acmsltAmtTotal" dataType="number" name="실적금총계(원)"></w2:column>
						<w2:column id="acmsltAmtMon01" dataType="number" name="월별 실적금(원) -1월"></w2:column>
						<w2:column id="acmsltAmtMon02" dataType="number" name="월별 실적금(원) -2월"></w2:column>
						<w2:column id="acmsltAmtMon03" dataType="number" name="월별 실적금(원) -3월"></w2:column>
						<w2:column id="acmsltAmtMon04" dataType="number" name="월별 실적금(원) -4월"></w2:column>
						<w2:column id="acmsltAmtMon05" dataType="number" name="월별 실적금(원) -5월"></w2:column>
						<w2:column id="acmsltAmtMon06" dataType="number" name="월별 실적금(원) -6월"></w2:column>
						<w2:column id="acmsltAmtMon07" dataType="number" name="월별 실적금(원) -7월"></w2:column>
						<w2:column id="acmsltAmtMon08" dataType="number" name="월별 실적금(원) -8월"></w2:column>
						<w2:column id="acmsltAmtMon09" dataType="number" name="월별 실적금(원) -9월"></w2:column>
						<w2:column id="acmsltAmtMon10" dataType="number" name="월별 실적금(원) -10월"></w2:column>
						<w2:column id="acmsltAmtMon11" dataType="number" name="월별 실적금(원) -11월"></w2:column>
						<w2:column id="acmsltAmtMon12" dataType="number" name="월별 실적금(원) -12월"></w2:column>
						<w2:column id="timeAddExcclcAmt" dataType="number" name="40시간 추가정산금(원)"></w2:column>
						<w2:column id="updtRsn" dataType="text" name="수정사유"></w2:column>
					</w2:columnInfo>
					<w2:data use="false"></w2:data>
				</w2:dataList>
			</w2:dataCollection>
			<w2:workflowCollection></w2:workflowCollection>
		</xf:model>
		<script lazy="false" type="text/javascript"><![CDATA[
	scwin.initData = {
		"isValidate" : false,
		"isSaveProcess" : false,
		"acbMappingCdObj" : {
			"bplcNm" : "cmmnCd"
		},
		"acbMappingNmObj" : {
			"basinNm" : "upperCmmnCdNm",
			"deptNm" : "upperCmmnCdNm2"
		},
		"valInfo" : [
			{id : "bplcNm", maxLength : 40, mandatory : true},
			{id : "bassAmtMon01", maxByteLength : 22, number : true},
			{id : "bassAmtMon02", maxByteLength : 22, number : true},
			{id : "bassAmtMon03", maxByteLength : 22, number : true},
			{id : "bassAmtMon04", maxByteLength : 22, number : true},
			{id : "bassAmtMon05", maxByteLength : 22, number : true},
			{id : "bassAmtMon06", maxByteLength : 22, number : true},
			{id : "bassAmtMon07", maxByteLength : 22, number : true},
			{id : "bassAmtMon08", maxByteLength : 22, number : true},
			{id : "bassAmtMon09", maxByteLength : 22, number : true},
			{id : "bassAmtMon10", maxByteLength : 22, number : true},
			{id : "bassAmtMon11", maxByteLength : 22, number : true},
			{id : "bassAmtMon12", maxByteLength : 22, number : true},
			{id : "acmsltAmtMon01", maxByteLength : 22, number : true},
			{id : "acmsltAmtMon02", maxByteLength : 22, number : true},
			{id : "acmsltAmtMon03", maxByteLength : 22, number : true},
			{id : "acmsltAmtMon04", maxByteLength : 22, number : true},
			{id : "acmsltAmtMon05", maxByteLength : 22, number : true},
			{id : "acmsltAmtMon06", maxByteLength : 22, number : true},
			{id : "acmsltAmtMon07", maxByteLength : 22, number : true},
			{id : "acmsltAmtMon08", maxByteLength : 22, number : true},
			{id : "acmsltAmtMon09", maxByteLength : 22, number : true},
			{id : "acmsltAmtMon10", maxByteLength : 22, number : true},
			{id : "acmsltAmtMon11", maxByteLength : 22, number : true},
			{id : "acmsltAmtMon12", maxByteLength : 22, number : true}
			/* {id : "timeAddExcclcAmt", maxByteLength : 15, number : true} */
		]
	};

	/**
	 * 화면 초기화에 필요한 로직을 수행한다.
	 * @param
	 * @return
	 */
	scwin.initScreen = function() {
		grdDrspExcclcList.setHeaderClass("hBassAmtMon12", "border-right");
		// 화면초기화 공통 함수 호출
		comLib.initForm($p, "ECSCL2400000", {"initScreenCallback" : scwin.searchDatas});
	};

	/**
	 * 화면 초기 데이터들을 조회한다.
	 * @param
	 * @return
	 */
	scwin.searchDatas = function() {
		// 조회조건 설정
		scwin.initSearchParam();
		// 화면 데이터 조회
		scwin.btnInqire_onclick();
	};

	/**
	 * 조회조건 초기화에 필요한 로직을 수행한다.
	 * @param
	 * @return
	 */
	scwin.initSearchParam = function() {
		dmaSearchParam.set("strtDt", utilLib.getCurrentDate("yyyy"));
	};

	/**
	 * 조회조건에 맞게 data를 조회한다.
	 * @param
	 * @return
	 */
	scwin.btnInqire_onclick = function() {
		var strtDate = dmaSearchParam.get("strtDt");
		var queryString = `?strtDt=${strtDate}`;

		if (String(strtDate).length != 4) {
			// 조회기간이 올바르지 않습니다.
			alert(utilLib.getMessage("ECS.INFO.00011")[0]);
			return;
		}

		var option = {
			action : "cl/drexcclc/retrieve-drsp-excclc.do"
				+ queryString,
			method : "get",
			resData : dltDrspExcclcList,
			success : "scwin.inqireCallback",
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	/**
	 * 조회 CallBack 실행한다.
	 * @param
	 * @return
	 */
	scwin.inqireCallback = function() {
		spnTotalRow.setValue(dltDrspExcclcList.getRowCount());
		var mandatoryList = scwin.initData.valInfo.filter(obj => obj.mandatory);

		for (var i = 0; i < dltDrspExcclcList.getRowCount(); i++) {
			mandatoryList.forEach(obj => {
				grdDrspExcclcList.setCellReadOnly(i, obj.id, true);
			});
		}
		scwin.initData.isValidate = false;
	};

	/**
	 * 그리드뷰 행을 추가한다.
	 * @param
	 * @return
	 */
	scwin.btnAddRow_onclick = function() {
		var newIndex = dltDrspExcclcList.insertRow();

		dltDrspExcclcList.setCellData(newIndex, "excclcYear", dmaSearchParam.get("strtDt"));
		grdDrspExcclcList.setFocusedCell(newIndex, "bplcNm", true);
	};

	/**
	 * 그리드뷰 행을 삭제한다.
	 * @param
	 * @return
	 */
	scwin.btnDelRow_onclick = function() {
		var rowIndexsList = grdDrspExcclcList.getAllFocusedRowIndex();

		dltDrspExcclcList.removeRows(rowIndexsList);
	};

	/**
	 * 그리드뷰의 내용을 검증한다.
	 * @param
	 * @return
	 */
	scwin.btnValidate_onclick = function(confirmValue) {
		if (confirmValue == true || confirmValue == undefined) {
			if (dltDrspExcclcList.getModifiedData() == "") {
				// 처리할 데이터가 없습니다.
				comLib.alert($p, utilLib.getMessage("SCM.INFO.00304"));
				return;
			}

			if (utilLib.validateGridView(grdDrspExcclcList, scwin.initData.valInfo)) {
				var columnList = scwin.initData.valInfo.filter(obj => obj.mandatory).flatMap(obj => obj.id.replace("bplcNm", "bplcCdId"));
				if (ecsLib.gridViewPkDuplicationCheck(grdDrspExcclcList, dltDrspExcclcList, columnList)) {
					// 중복 데이터가 있습니다.
					return;
				}

				if (ecsLib.validateGridViewAcb(grdDrspExcclcList, dltAutoCondition1, scwin.initData.acbMappingCdObj, scwin.initData.acbMappingNmObj)) {
					// 해당하는 {컬럼명}이(가) 존재하지 않습니다.
					return;
				}
				scwin.initData.isValidate = true;
				if (scwin.initData.isSaveProcess) {
					scwin.initData.isSaveProcess = false;
					scwin.btnSave_onclick();
				} else {
					// 데이터 검증이 완료되었습니다.
					comLib.alert($p, utilLib.getMessage("ECS.INFO.00102"));
				}
			}
		} else {
			scwin.initData.isSaveProcess = false;
		}
	};

	/**
	 * 그리드뷰의 내용을 수정/저장한다.
	 * @param
	 * @return
	 */
	scwin.btnSave_onclick = function() {
		scwin.initData.isSaveProcess = false;
		if (dltDrspExcclcList.getModifiedData() == "") {
			// 처리할 데이터가 없습니다.
			comLib.alert($p, utilLib.getMessage("SCM.INFO.00304"));
			return;
		}

		if (scwin.initData.isValidate) {
			var addCount = 0;
			var modifyCount = 0;
			var delCount = 0;
			dltDrspExcclcList.getModifiedJSON().forEach(obj => {
				var rowStatus = obj.rowStatus;
				switch(rowStatus) {
					case "C":
						// 추가
						addCount++;
						break;
					case "U":
						// 수정
						modifyCount++;
						break;
					case "E":
						// 삭제
						delCount++;
						break;
					default:
						break;
				}
			});
			var extendMsg = ecsLib.extendCustomSaveMsg(addCount, modifyCount, delCount);
			// 변경된 내역이 있습니다.\n저장 하시겠습니까? \n수정사유를 입력하세요.
			ecsLib.saveRsn($p, `${dltDrspExcclcList.getID()}.updtRsn`, utilLib.getMessage("SCM.INFO.00239")[0] + extendMsg, "scwin.saveConfirmCallback");
		} else {
			scwin.initData.isSaveProcess = true;
			// 데이터 검증 후 저장 가능합니다.\n검증하시겠습니까?
			comLib.confirm($p, utilLib.getMessage("ECS.INFO.00101"), "scwin.btnValidate_onclick", true);
			return;
		}
	};

	/**
	 * 수정/저장 ComfirmCallBack 실행한다.
	 * @param
	 * @return
	 */
	scwin.saveConfirmCallback = function() {
		var requestData = {};
		requestData.dltDrspExcclcList = dltDrspExcclcList.getModifiedJSON();

		var option = {
			action : "cl/drexcclc/process-drsp-excclc.do",
			reqData : requestData,
			success : "scwin.saveConfirmSuccessCallback",
			savedToken : true,
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	/**
	 * 수정/저장 CallBack 실행한다.
	 * @param <Object> resBody
	 * @return
	 */
	scwin.saveConfirmSuccessCallback = function(resBody) {
		comLib.alert($p, resBody.message.code_name);

		scwin.btnInqire_onclick();
	};

	/**
	 * 작업중이던 내용을 취소한다.
	 * @param
	 * @return
	 */
	scwin.btnCancl_onclick = function() {
		scwin.btnInqire_onclick();
	};

	/**
	 * 데이터컬렉션의 추가/변경/삭제 시 이벤트
	 * @param
	 * @return
	 */
	scwin.dltDrspExcclcList_ondatachange = function(info) {
		scwin.initData.isValidate = false;
	};

	scwin.grdDrspExcclcList_onafteredit = function(row,col,value) {
		ecsLib.updateGridViewFontColor(grdDrspExcclcList, row, col);
	};

	//============================================================================================
	// 엑셀
	//============================================================================================
	/**
	 * 그리드의 내용을 엑셀로 다운로드 한다.
	 * @return
	 */
	scwin.btnDownExcel_onclick = function() {
		var menuNm = $p.getComponentById("wfm_title").scope.$p.getComponentById("tbxScreenTitle").getValue();
		var subTitleNm = spnSubTitle.getValue();
		// 엑셀 내부 타이틀 추가_240105
		var infoArr = [];
		var infoObj = {
			rowIndex 	: 0,
			colIndex 	: 0,
			rowSpan 	: 0,
			colSpan 	: 31,
			text 		: `${menuNm}_` + `${subTitleNm}`,
			textAlign 	: "left"
		};
		infoArr.push(infoObj);

		// 데이터가 없어도 탬플릿만 다운받을 수 있게 comLib.downloadExcel 말고 grdID.advancedExcelDownload 적용_231113
		options = {
			fileName : `${menuNm}_` + `${subTitleNm}.xlsx`,
			type : 1,
			autoSizeColumn : true,
			startRowIndex : 1,
			startColumnIndex : 0,
			rowHeight : 40,
			useDataFormat: true,
			applyDataFormat : true,
			useStyle: true,
			hidden: 1
		}
		grdDrspExcclcList.advancedExcelDownload(options, infoArr);
	};

	/**
	 * 엑셀의 내용을 그리드에 업로드 한다.
	 * @return
	 */
	scwin.btnUploadExcel_onclick = function() {
		var options = {
			type : 1,
			headerExist : 1,
			startRowIndex : 1,
			startColumnIndex : 0,
			endColumnIndex : 30,
			sheetNo : 0,
			append : 0,
			status: "C",
			useMaxByteLength : true
		};
		comLib.uploadExcel(grdDrspExcclcList, options);
	};

	/**
	 * 엑셀 내용을 그리드에 저장한다.
	 * @return
	 */
	scwin.grdDrspExcclcList_onfilereadend = function(value) {
		var dltData = dltDrspExcclcList.getAllJSON();
		var excclcYear = dmaSearchParam.get("strtDt");
		var dltAuto1 = dltAutoCondition1.getAllJSON();
		// set JSON
		for (var idx = 0; idx < dltData.length; idx++) {
			var bplcCdId = (dltAuto1.find(obj => obj.cmmnCd == dltData[idx].bplcNm) || 0).cmmnCd;
			dltDrspExcclcList.setCellData(idx, "excclcYear", excclcYear);
			dltDrspExcclcList.setCellData(idx, "bplcNm", bplcCdId);
		}
	};
	]]></script>
	</head>
	<body>
		<w2:wframe id="wfm_title" class="wfm_title" src="/ui/common/navigator.xml"></w2:wframe>
		<!--< w2:pageInherit id="comPage" src="/ui/common/content_common.xml"></w2:pageInherit> -->
		<xf:group class="wrap">
			<xf:group class="search-box">
				<xf:group id="grpInqire" class="list">
					<xf:group class="w2tb" tagname="table">
						<w2:attributes>
							<w2:summary></w2:summary>
						</w2:attributes>
						<xf:group tagname="caption"></xf:group>
						<xf:group tagname="colgroup">
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
						</xf:group>
						<xf:group tagname="tr">
							<xf:group class="w2tb_th cw1" tagname="th">
								<w2:attributes>
									<w2:scope>row</w2:scope>
								</w2:attributes>
