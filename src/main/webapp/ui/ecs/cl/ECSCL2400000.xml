				<w2:dataList id="dltDrspExcclcList" baseNode="list" repeatNode="map" saveRemovedData="true" ev:oncelldatachange="scwin.dltDrspExcclcList_ondatachange"
					ev:onremoverow="scwin.dltDrspExcclcList_ondatachange" ev:oninsertrow="scwin.dltDrspExcclcList_ondatachange">
					<w2:columnInfo>
						<w2:column id="excclcYear" dataType="number" name="정산년도"></w2:column>
						<w2:column id="basinNm" dataType="text" name="유역"></w2:column>
						<w2:column id="deptNm" dataType="text" name="부서"></w2:column>
						<w2:column id="bplcNm" dataType="text" name="사업장"></w2:column>
						<w2:column id="bplcCdId" dataType="text" name="사업장코드ID"></w2:column>
						<w2:column id="excclcAmtTotal" dataType="number" name="정산금총계(원)"></w2:column>
						<w2:column id="bassAmtTotal" dataType="number" name="기본금총계(원)"></w2:column>
