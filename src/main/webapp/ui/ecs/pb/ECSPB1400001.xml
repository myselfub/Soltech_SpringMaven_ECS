<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet href="/resources/css/modal.css" type="text/css"?>
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:w2="http://www.inswave.com/websquare"
	xmlns:xf="http://www.w3.org/2002/xforms">
	<head>
		<!--
			========================================================================
			* 소스명 : ECSPB1400001.xml
			* 설 명 : 에너지 계획/건설 계획수정
			* 작성일 : 2024.02.07
			* 담당자: Soltech 정기석
			* << 개정이력 >>
			* 수정일 수정자 수정내용
			* 2024.02.07 Soltech 정기석 최초 작성
			========================================================================
		-->
		<w2:type>DEFAULT</w2:type>
		<w2:buildDate />
		<xf:model>
			<xf:instance>
				<data xmlns="" />
			</xf:instance>
			<w2:dataCollection baseNode="map">
				<w2:dataList id="dltAutoCondition1" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<w2:column id="clsCd" dataType="text" name="대분류 코드"></w2:column>
						<w2:column id="clsCdNm" dataType="text" name="대분류 이름"></w2:column>
						<w2:column id="cmmnCd" dataType="text" name="소분류 코드"></w2:column>
						<w2:column id="cmmnCdNm" dataType="text" name="소분류 이름"></w2:column>
						<w2:column id="upperCmmnCd" dataType="text" name="상위 소분류 코드1"></w2:column>
						<w2:column id="upperCmmnCdNm" dataType="text" name="상위 소분류 이름1"></w2:column>
						<w2:column id="upperCmmnCd2" dataType="text" name="상위 소분류 코드2"></w2:column>
						<w2:column id="upperCmmnCdNm2" dataType="text" name="상위 소분류 이름2"></w2:column>
						<w2:column id="upperCmmnCd3" dataType="text" name="상위 소분류 코드3"></w2:column>
						<w2:column id="upperCmmnCdNm3" dataType="text" name="상위 소분류 이름3"></w2:column>
					</w2:columnInfo>
				</w2:dataList>
				<w2:dataMap id="dmaPlanCnstrc" baseNode="map">
					<w2:keyInfo>
						<w2:key id="planEsntlId" dataType="text" name="계획 -계획고유ID"></w2:key>
						<w2:key id="planBsnsNm" dataType="text" name="계획 - 사업명"></w2:key>
						<w2:key id="setcscNm" dataType="text" name="계획 - 발전원"></w2:key>
						<w2:key id="ecsSetcscDivCd" dataType="text" name="계획 -ECS발전원구분코드"></w2:key>
						<w2:key id="planFoundngDe" dataType="text" name="계획 - 수립일"></w2:key>
						<w2:key id="planChrgDeptNm" dataType="text" name="계획 - 담당부서"></w2:key>
						<w2:key id="ecsChrgDeptId" dataType="text" name="계획 - ECS담당부서ID"></w2:key>
						<w2:key id="planChargerNm" dataType="text" name="계획 - 담당자"></w2:key>
						<w2:key id="planChargerEmpno" dataType="text" name="계획 - 담당자사원번호"></w2:key>
						<w2:key id="planEqpCpcty" dataType="number" name="계획 - 계획설비용량"></w2:key>
						<w2:key id="planAmt" dataType="number" name="계획 - 계획금액"></w2:key>
						<w2:key id="cnstrcEsntlId" dataType="text" name="건설 - 건설고유ID"></w2:key>
						<w2:key id="cnstrcEqpCpcty" dataType="number" name="건설 - 건설설비용량"></w2:key>
						<w2:key id="cmsBsnsCd" dataType="text" name="건설 - CMS사업코드"></w2:key>
						<w2:key id="cmsPrjctCd" dataType="text" name="건설 - CMS프로젝트코드"></w2:key>
						<w2:key id="cmsPrjctSqncIdtfr" dataType="text" name="건설 - CMS프로젝트회차식별자"></w2:key>
						<w2:key id="ordgTit" dataType="text" name="건설 - 계약명"></w2:key>
						<w2:key id="lnrtrDivNm" dataType="text" name="건설 - 장단기구분"></w2:key>
						<w2:key id="bsnsDivNm" dataType="text" name="건설 - 사업구분"></w2:key>
						<w2:key id="bsnsMngdeptNm" dataType="text" name="건설 - 건설주관부서"></w2:key>
						<w2:key id="edptNm" dataType="text" name="건설 - 담당부서"></w2:key>
						<w2:key id="edptChargerId" dataType="text" name="건설 - 담당자 사원번호"></w2:key>
						<w2:key id="edptChargerNm" dataType="text" name="건설 - 담당자"></w2:key>
						<w2:key id="strwrkDe" dataType="text" name="건설 - 착공일"></w2:key>
						<w2:key id="lastCompetDe" dataType="text" name="건설 - 준공일"></w2:key>
						<w2:key id="absltCntrwkPdInfo" dataType="text" name="건설 - 절대공사기간정보"></w2:key>
						<w2:key id="lastCntrwkPdInfo" dataType="text" name="건설 - 최종공사기간정보"></w2:key>
						<w2:key id="cntrctEntrpsNm" dataType="text" name="건설 - 계약업체"></w2:key>
						<w2:key id="entrpsRprsrNm" dataType="text" name="건설 - 대표자"></w2:key>
						<w2:key id="sptAddr" dataType="text" name="건설 - 현장소재지"></w2:key>
						<w2:key id="competam" dataType="text" name="건설 - 준공금액"></w2:key>
						<w2:key id="prgsSttus" dataType="text" name="진행현황"></w2:key>
						<w2:key id="rmCtnt" dataType="text" name="계획 - 내용"></w2:key>
						<w2:key id="updtRsn" dataType="text" name="수정사유"></w2:key>
					</w2:keyInfo>
				</w2:dataMap>
			</w2:dataCollection>
			<w2:workflowCollection></w2:workflowCollection>
		</xf:model>
		<script lazy="false" type="text/javascript"><![CDATA[
	scwin.initData = {};

	scwin.onpageunload = function() {
		scwin.initData.parent.$p.getComponentById(scwin.initData.parent.$p.getPopupId()).setDisabled(false);
		scwin.initData.parent.$p.getComponentById(scwin.initData.parent.$p.getFrameId()).setDisabled(false);
	};

	/**
	 * 화면 초기화에 필요한 로직을 수행한다.
	 * @param
	 * @return
	 */
	scwin.initScreen = function() {
		scwin.initData.parent = $p.parent();
		// 부모창 <input> id를 param(this.id)으로 가져옴
		scwin.param = JSON.parse($p.getPopupParam());
		// 화면초기화 공통 함수 호출
		comLib.initForm($p, "ECSPB1400001");
		setTimeout(() => {
			scwin.initDataSet();
		}, 200);
	};

	scwin.initDataSet = function() {
		dmaPlanCnstrc.setJSON(scwin.param.dataMap);
		ibxPlanBsnsNm.setDisabled(true);
		acbSetcscNm.setDisabled(true);
	};

	/**
	 * 수정 후 버튼 클릭시 해당 내용을 수정할지 물어본다.
	 * @param
	 * @return
	 */
	scwin.btnEdit_onclick = function() {
		// 저장 하시겠습니까? \n수정사유를 입력하세요.
		ecsLib.saveRsn($p, `${dmaPlanCnstrc.getID()}.updtRsn`, utilLib.getMessage("SCM.INFO.00321")[0], "scwin.updateConfirmCallback");
	};

	/**
	 * 수정 ComfirmCallBack 실행한다.
	 * @param
	 * @return
	 */
	scwin.updateConfirmCallback = function() {
		var requestData = {};
		requestData.dmaPlanCnstrc = dmaPlanCnstrc.getJSON();

		var option = {
			action : "/pb/plancnstrc/update-plan-cpcty-amt-ctnt.do",
			reqData : requestData,
			success : "scwin.updateCallback",
			savedToken : true,
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	/**
	 * 수정 updateCallBack 실행한다.
	 * @param
	 * @return
	 */
	scwin.updateCallback = function() {
		var rowIndex = scwin.initData.parent.$p.getComponentById("grdPlanList").getFocusedRowIndex();
		//scwin.initData.parent.scwin.btnInqire_onclick(rowIndex);
		scwin.initData.parent.scwin.btnInqire_onclick(0);

		scwin.btnCancl_onclick();
	};

	/**
	 * 버튼 클릭시 해당 모달을 닫는다.
	 * @param
	 * @return
	 */
	scwin.btnCancl_onclick = function() {
		// 모달 창 닫기
		$p.closePopup();
	};]]></script>
	</head>
	<body ev:onpageunload="scwin.onpageunload">
		<!-- <w2:wframe id="wfm_title" class="wfm_title" src="/ui/common/navigator.xml"></w2:wframe> -->
		<!--< w2:pageInherit id="comPage" src="/ui/common/content_common.xml"></w2:pageInherit> -->
		<w2:wframe id="wframeLeft" src="/ui/common/content_board.xml"></w2:wframe>
		<xf:group class="wrap">
			<xf:group class="search-box">

			</xf:group>
			<xf:group class="popup-content-area">
				<xf:group class="con-box" style="height:16rem; overflow:auto;">
					<xf:group class="view-box box">
						<xf:group id="grpDtl" class="w2tb" tagname="table">
							<xf:group tagname="colgroup">
								<xf:group class="detail_tit" tagname="col"></xf:group>
								<xf:group tagname="col"></xf:group>
								<xf:group tagname="col"></xf:group>
								<xf:group tagname="col"></xf:group>
								<xf:group tagname="col"></xf:group>
								<xf:group tagname="col"></xf:group>
							</xf:group>
							<xf:group tagname="tr">
								<xf:group class="w2tb_th left" tagname="th">
									<w2:attributes>
										<w2:colspan>6</w2:colspan>
										<w2:rowspan>1</w2:rowspan>
									</w2:attributes>
									<xf:group class="btn-group">
										<w2:span label="계획 상세보기 " style="font-size:1rem; padding-left:1rem;"></w2:span>
										<!-- userData1="Q" -->
										<w2:anchor id="btnPlanDtl" class="pb-dtl fa fa-minus" outerDiv="false" title="접기" ev:onclick="scwin.trPlanDtlDisplay">
											<xf:label><![CDATA[]]>
											</xf:label>
										</w2:anchor>
										<xf:group class="fr btn-group">
											<!-- userData1="N" -->
											<w2:anchor id="btnNew1" ev:onclick="scwin.btnNew_onclick" outerDiv="false" toolTip="신규 계획을 저장하기 위해 입력창 활성화">
												<xf:label><![CDATA[신규등록]]></xf:label>
											</w2:anchor>
											<!-- userData1="Q" -->
											<w2:anchor id="btnPlanSearch" class="fa btn_sh" outerDiv="false" ev:onclick="scwin.btnPlanSearch_onclick" toolTip="기존 계획을 조회하여 건설통합(CMS) 건설 추가">
												<xf:label>
													<![CDATA[계획조회]]></xf:label>
											</w2:anchor>
										</xf:group>
									</xf:group>
								</xf:group>
							</xf:group>
							<xf:group tagname="tr" class="tr-dtl-plan">
								<xf:group class="w2tb_th right req" tagname="th">
									<w2:span label="사업명"></w2:span>
								</xf:group>
								<xf:group class="w2tb_td" tagname="td">
									<w2:attributes>
										<w2:colspan>5</w2:colspan>
										<w2:rowspan>1</w2:rowspan>
									</w2:attributes>
									<xf:input id="ibxPlanBsnsNm" ref="data:dmaPlanCnstrc.planBsnsNm" maxByteLength="1000"></xf:input>
								</xf:group>
							</xf:group>
							<xf:group tagname="tr" class="tr-dtl-plan">
								<xf:group class="w2tb_th right req" tagname="th">
									<w2:span label="발전원"></w2:span>
								</xf:group>
								<xf:group class="w2tb_td" tagname="td">
									<w2:attributes>
										<w2:colspan>2</w2:colspan>
										<w2:rowspan>1</w2:rowspan>
									</w2:attributes>
									<w2:autoComplete id="acbSetcscNm" displayMode="label" editType="select" search="contain" submenuSize="auto"
										useKeywordHighlight="true" visibleRowNum="15" chooseOptionLabel="- 선택 -" chooseOption="true" ref="data:dmaPlanCnstrc.ecsSetcscDivCd">
										<w2:choices>
											<w2:itemset nodeset="data:dltAutoCondition1">
												<w2:label ref="cmmnCdNm"></w2:label>
												<w2:value ref="cmmnCd"></w2:value>
											</w2:itemset>
										</w2:choices>
									</w2:autoComplete>
								</xf:group>
								<xf:group class="w2tb_th right req" tagname="th">
									<w2:span label="금액(원)"></w2:span>
								</xf:group>
								<xf:group class="w2tb_td" tagname="td">
									<w2:attributes>
										<w2:colspan>2</w2:colspan>
										<w2:rowspan>1</w2:rowspan>
									</w2:attributes>
									<xf:input id="ibxPlanAmt" dataType="number" mandatory="true" ref="data:dmaPlanCnstrc.planAmt" maxByteLength="22"
										displayFormatter="ecsLib.dsplZeroFrmt"></xf:input>
								</xf:group>
							</xf:group>
							<xf:group tagname="tr" class="tr-dtl-plan">
								<xf:group class="w2tb_th right req" tagname="th">
									<w2:span id="spnPlanEqpCpcty" label="설비용량&lt;br/&gt;"></w2:span>
								</xf:group>
								<xf:group class="w2tb_td" tagname="td">
									<w2:attributes>
										<w2:colspan>2</w2:colspan>
										<w2:rowspan>1</w2:rowspan>
									</w2:attributes>
									<xf:input id="ibxPlanEqpCpcty" dataType="number" mandatory="true" ref="data:dmaPlanCnstrc.planEqpCpcty" maxByteLength="22"
										displayFormatter="ecsLib.dsplZeroFrmt"></xf:input>
								</xf:group>
								<xf:group class="w2tb_th right" tagname="th">
									<w2:span label="수립일"></w2:span>
								</xf:group>
								<xf:group class="w2tb_td" tagname="td">
									<w2:attributes>
										<w2:colspan>2</w2:colspan>
										<w2:rowspan>1</w2:rowspan>
									</w2:attributes>
									<xf:group class="mix-box">
										<xf:group class="cw20">
											<w2:span id="icaPlanFoundngDe" ref="data:dmaPlanCnstrc.planFoundngDe" displayFormat="####.##.##"></w2:span>
										</xf:group>
									</xf:group>
								</xf:group>
							</xf:group>
							<xf:group tagname="tr" class="tr-dtl-plan">
								<xf:group class="w2tb_th right" tagname="th">
									<w2:span label="담당부서"></w2:span>
								</xf:group>
								<xf:group class="w2tb_td" tagname="td">
									<w2:attributes>
										<w2:colspan>2</w2:colspan>
										<w2:rowspan>1</w2:rowspan>
									</w2:attributes>
									<xf:group class="mix-box">
										<xf:group class="cw20">
											<w2:span id="ibxPlanChrgDeptNm" ref="data:dmaPlanCnstrc.planChrgDeptNm"></w2:span>
										</xf:group>
									</xf:group>
								</xf:group>
								<xf:group class="w2tb_th right" tagname="th">
									<w2:span label="담당자"></w2:span>
								</xf:group>
								<xf:group class="w2tb_td" tagname="td">
									<w2:attributes>
										<w2:colspan>2</w2:colspan>
										<w2:rowspan>1</w2:rowspan>
									</w2:attributes>
									<xf:group class="mix-box">
										<xf:group class="cw20">
											<w2:span id="ibxPlanChargerNm" ref="data:dmaPlanCnstrc.planChargerNm"></w2:span>
										</xf:group>
									</xf:group>
								</xf:group>
							</xf:group>
							<xf:group tagname="tr" class="tr-dtl-plan">
								<xf:group class="w2tb_th right" tagname="th">
									<w2:span label="계획내용"></w2:span>
								</xf:group>
								<xf:group class="w2tb_td" tagname="td">
									<w2:attributes>
										<w2:colspan>5</w2:colspan>
										<w2:rowspan>1</w2:rowspan>
									</w2:attributes>
									<xf:textarea id="ibxRmCtnt" mandatory="true" ref="data:dmaPlanCnstrc.rmCtnt" style="height:5rem;" maxByteLength="4000"></xf:textarea>
								</xf:group>
							</xf:group>
						</xf:group>
					</xf:group>
				</xf:group>
			</xf:group>
			<xf:group class="footer">
				<xf:group class="btn-group">
					<!-- userData1="S" -->
					<w2:anchor id="btnEdit" ev:onclick="scwin.btnEdit_onclick" outerDiv="false">
						<xf:label><![CDATA[수정]]></xf:label>
					</w2:anchor>
					<!-- userData1="CC" -->
					<w2:anchor id="btnCancle" ev:onclick="scwin.btnCancl_onclick" outerDiv="false">
						<xf:label><![CDATA[취소]]></xf:label>
					</w2:anchor>
				</xf:group>
			</xf:group>
		</xf:group>
	</body>
</html>