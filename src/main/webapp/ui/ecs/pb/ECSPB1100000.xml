	<head>
		<!--
			========================================================================
			* 소스명 : ECSPB1100000.xml
			* 설 명 : 에너지 계획/건설 등록_전자문서등록(프로젝트문서)
			* 작성일 : 2023.06.12
			* 담당자: Soltech 위해서
			* << 개정이력 >>
			* 수정일 수정자 수정내용
			* 2023.06.12 Soltech 위해서 최초 작성
			========================================================================
		-->
		<w2:type>DEFAULT</w2:type>
		<w2:buildDate />
		<xf:model>
			<xf:instance>
				<data xmlns="" />
			</xf:instance>
			<w2:dataCollection baseNode="map">
				<w2:dataMap id="dmaSearchParam" baseNode="map">
					<w2:keyInfo>
						<w2:key id="strtDt" dataType="number" name="조회시작일"></w2:key>
						<w2:key id="endDt" dataType="number" name="조회종료일"></w2:key>
						<w2:key id="ordgTit" dataType="text" name="계약명"></w2:key>
						<w2:key id="edptNm" dataType="text" name="시행부서명"></w2:key>
					</w2:keyInfo>
				</w2:dataMap>
				<w2:dataList id="dltOrdgTitList" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<w2:column id="num" dataType="number" name="No"></w2:column>
						<w2:column id="ordgTit" dataType="text" name="계약명"></w2:column>
						<w2:column id="lnrtrDivCd" dataType="text" name="장단기구분코드"></w2:column>
						<w2:column id="lnrtrDivNm" dataType="text" name="장단기구분"></w2:column>
						<w2:column id="prjctDivCd" dataType="text" name="프로젝트구분코드"></w2:column>
						<w2:column id="prjctDivNm" dataType="text" name="프로젝트구분명"></w2:column>
						<w2:column id="ntntrsSportYn" dataType="text" name="국고지원여부(예산)"></w2:column>
						<w2:column id="bsnsMngdeptNm" dataType="text" name="주관부서"></w2:column>
						<w2:column id="edptNm" dataType="text" name="시행부서명"></w2:column>
						<w2:column id="edptChargerNm" dataType="text" name="시행담당자명"></w2:column>
						<w2:column id="strwrkDe" dataType="text" name="착공일"></w2:column>
						<w2:column id="lastCompetDe" dataType="text" name="준공일"></w2:column>
						<w2:column id="cntrctEntrpsNm" dataType="text" name="계약업체명"></w2:column>
						<w2:column id="entrpsRprsrNm" dataType="text" name="대표자명"></w2:column>
						<w2:column id="sptAddr" dataType="text" name="현장소재지"></w2:column>
						<w2:column id="bsnsDivNm" dataType="text" name="사업구분명"></w2:column>
						<w2:column id="absltCntrwkPdInfo" dataType="text" name="절대공사기간정보"></w2:column>
						<w2:column id="lastCntrwkPdInfo" dataType="text" name="최종공사기간정보"></w2:column>
						<w2:column id="competam" dataType="text" name="준공금액"></w2:column>
						<w2:column id="cmsBsnsCd" dataType="text" name="CMS사업코드"></w2:column>
						<w2:column id="cmsPrjctCd" dataType="text" name="CMS프로젝트코드"></w2:column>
						<w2:column id="cmsPrjctSqncIdtfr" dataType="text" name="CMS프로젝트회차식별자"></w2:column>
					</w2:columnInfo>
				</w2:dataList>
			</w2:dataCollection>
			<w2:workflowCollection></w2:workflowCollection>
		</xf:model>
		<script lazy="false" type="text/javascript"><![CDATA[
	/**
	 * 화면 초기화에 필요한 로직을 수행한다.
	 * @param
	 * @return
	 */
	scwin.initScreen = function() {
		scwin.param = JSON.parse($p.getPopupParam());
		// 화면초기화 공통 함수 호출
		comLib.initForm($p, "ECSPB1100000");
		scwin.searchDatas();
	};

	/**
	 * 화면 초기 데이터들을 조회한다.
	 * @param
	 * @return
	 */
	scwin.searchDatas = function() {
		// 착공일 초기설정
		scwin.initSearchParam();
		// 데이터 조회
		scwin.btnInqire_onclick();
	};

	/**
	 * 조회조건 초기화에 필요한 로직을 수행한다.
	 * @param
	 * @return
	 */
	scwin.initSearchParam = function() {
		dmaSearchParam.set("strtDt", utilLib.addMonth(utilLib.getCurrentDate("yyyyMMdd"), -1));
		dmaSearchParam.set("endDt", utilLib.getCurrentDate());
	};

	/**
	 * 조회조건에 맞게 data를 조회한다.
	 * @param
	 * @return
	 */
	scwin.btnInqire_onclick = function() {
		var strtDate = dmaSearchParam.get("strtDt");
		var endDate = dmaSearchParam.get("endDt");
		var ordgTit = dmaSearchParam.get("ordgTit");
		var edptNm = dmaSearchParam.get("edptNm");

		if (utilLib.minusDates(strtDate, endDate) > 365 ? true : false) {
			alert("조회기간은 1년을 넘어갈 수 없습니다. 다시 설정해 주세요.");
			return;
		}

		var queryString = `?strtDt=${strtDate}`;
		queryString += `&endDt=${endDate}`;
		queryString += `&ordgTit=${ordgTit}`;
		queryString += `&edptNm=${edptNm}`;

		var option = {
			action : "pb/plancnstrc/retrieve-project.do"
				+ queryString,
			method : "get",
			resData : dltOrdgTitList,
			success : "scwin.inqireCallback",
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	/**
	 * 조회 CallBack 실행한다.
	 * @param
	 * @return
	 */
	scwin.inqireCallback = function() {
		spnTotalRow.setValue(dltOrdgTitList.getRowCount());
	};

	/**
	 * 셀을 선택 후 선택 버튼 클릭시 해당 내용을 상세내역으로 표출한다.
	 * @param
	 * @return
	 */
	scwin.btnEdit_onclick = function() {
		if (btnEdit.hasClass("hide")) {
			return;
		}
		var rowIndex = grdOrdgTitList.getFocusedRowIndex();
		var rowData = dltOrdgTitList.getRowJSON(rowIndex);

		$p.parent().$p.getComponentById(scwin.param.dmaId).setJSON(rowData);

		// 건설설비용량 사용 여부 처리
		if (scwin.param.dmaId.includes("dmaPlanCnstrc")) {
			$p.parent().scwin.setCnstrcDisabled(rowData);
		}
		/*
		else if (scwin.param.dmaId.includes("dmaSetcscDsusePrcsDtlHist")) {
		}
		*/

		// 모달 창 닫기
		$p.closePopup();
	};

	scwin.grdOrdgTitList_oncelldblclick = function(row, col, colId) {
		scwin.btnEdit_onclick();
	};
	]]></script>
	</head>
	<body>
		<!-- <w2:wframe id="wfm_title" class="wfm_title" src="/ui/common/navigator.xml"></w2:wframe> -->
		<!--< w2:pageInherit id="comPage" src="/ui/common/content_common.xml"></w2:pageInherit> -->
