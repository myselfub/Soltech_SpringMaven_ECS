<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet href="/resources/css/content.css" type="text/css"?>
<?xml-stylesheet href="/resources/css/content-layout.css" type="text/css"?>
<?xml-stylesheet href="/resources/css/animate.css" type="text/css"?>
<?xml-stylesheet href="/resources/css/font-awesome.min.css" type="text/css"?>
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:w2="http://www.inswave.com/websquare"
	xmlns:xf="http://www.w3.org/2002/xforms">
	<head>
		<!--
			========================================================================
			* 소스명 : ECSZZ0000006.xml
			* 설 명 : 공통코드검색하기 위한 프로그램
			* 작성일 : 2023.11.30
			* 담당자 : Soltech 위해서
			* << 개정이력 >>
			* 수정일 수정자 수정내용
			* 2023.11.30 Soltech 위해서 최초 작성
			========================================================================
		-->
		<w2:type>DEFAULT</w2:type>
		<w2:buildDate />
		<xf:model>
			<xf:instance>
				<data xmlns="" />
			</xf:instance>
			<w2:dataCollection baseNode="map">
				<w2:dataList id="dltCmmnCdList" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<w2:column id="clsCd" name="분류코드" dataType="text">
						</w2:column>
						<w2:column id="clsCdNm" name="공통코드" dataType="text">
						</w2:column>
						<w2:column id="cmmnCd" name="공통코드명" dataType="text">
						</w2:column>
						<w2:column id="cmmnCdNm" name="공통코드설명" dataType="text">
						</w2:column>
						<w2:column id="upperClsCd" name="상위분류코드" dataType="text">
						</w2:column>
						<w2:column id="upperCmmnCd" name="상위공통코드" dataType="text">
						</w2:column>
						<w2:column id="useYn" name="사용여부" dataType="text">
						</w2:column>
						<w2:column id="sortOrdr" name="정렬순서" dataType="text">
						</w2:column>
						<w2:column id="sapLnkYn" name="SAP연계여부" dataType="text">
						</w2:column>
						<w2:column id="usrDfnVu1" name="사용자정의기타1" dataType="text">
						</w2:column>
						<w2:column id="usrDfnVu2" name="사용자정의기타2" dataType="text">
						</w2:column>
						<w2:column id="usrDfnVu3" name="사용자정의기타3" dataType="text">
						</w2:column>
						<w2:column id="usrDfnVu4" name="사용자정의기타4" dataType="text">
						</w2:column>
						<w2:column id="usrDfnVu5" name="사용자정의기타5" dataType="text">
						</w2:column>
						<w2:column id="usrDfnVu6" name="사용자정의기타6" dataType="text">
						</w2:column>
						<w2:column id="usrDfnVu7" name="사용자정의기타7" dataType="text">
						</w2:column>
						<w2:column id="usrDfnVu8" name="사용자정의기타8" dataType="text">
						</w2:column>
					</w2:columnInfo>
				</w2:dataList>
				<w2:dataMap id="dmaInqireParam" baseNode="map">
					<w2:keyInfo>
						<w2:key id="clsCd" name="분류코드" dataType="text"></w2:key>
						<w2:key id="clsCdNm" name="분류코드명" dataType="text"></w2:key>
						<w2:key id="clsCdDc" name="분류코드설명" dataType="text"></w2:key>
						<w2:key id="useYn" name="사용여부" dataType="text"></w2:key>
					</w2:keyInfo>
				</w2:dataMap>
				<w2:dataList id="dltClsCdList" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<w2:column id="clsCd" name="clsCd" dataType="text">
						</w2:column>
						<w2:column id="clsCdNm" name="clsCdNm" dataType="text">
						</w2:column>
						<w2:column id="clsCdDc" name="clsCdDc" dataType="text">
						</w2:column>
						<w2:column id="useYn" name="useYn" dataType="text">
						</w2:column>
					</w2:columnInfo>
				</w2:dataList>
			</w2:dataCollection>
			<w2:workflowCollection></w2:workflowCollection>
		</xf:model>
		<script lazy="false" type="text/javascript"><![CDATA[
	/**
	 * 공통코드 정보 화면 초기화 작업을 수행한다.
	 * @param
	 * @return
	 */
	scwin.popupParam;
	scwin.initScreen = function() {
		scwin.popupParam=comLib.getPopupParam($p,["clsCd", "usrDfnVu", "usrDfnEtcVu"]);
		// 화면초기화 공통 함수 호출
		comLib.initForm($p, scwin.popupParam.popupID);

		// 초기화 한 dataMap에 공통분류코드를 설정
		dmaInqireParam.set("useYn", "Y");

		// 공통코드 조회
		comLib.setEnterKeyEvent(grpInqire, scwin.btnInqire_onclick);
		scwin.btnInqire_onclick();
	};

	/**
	 * 공통코드를 조회한다.
	 * @param
	 * @return
	 */
	scwin.btnInqire_onclick = function() {
		var requestData = {};
		dltClsCdList.removeAll();

		requestData.dmaInqireParam =dmaInqireParam.getJSON();

		var option = {action : "sc/cmmncd/retrieveClsCd.do",
			reqData : requestData,
			resData : dltClsCdList,
			success : "scwin.inqireClsCdCallback",
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	/**
	 * 공통코드 조회후 콜백 로직을 수행한다.
	 * @param <Object> resBody
	 * @return
	 */
	scwin.inqireClsCdCallback = function(resBody) {
		if(resBody.message.code == 'success'){
			if (dltClsCdList.getRowCount() > 0) {
				txtCnt.setValue(dltClsCdList.getRowCount());
			}
		}
		else{
			comLib.alert($p, "fail");
		}
	};

	/**
	 * 선택된 공통코드정보를 반환한다.
	 * @param
	 * @return
	 */
	scwin.btnCnfirm_onclick = function() {
		var rowIdx = grdClsCdList.getFocusedRowIndex();
		var colIdx = grdClsCdList.getFocusedColumnIndex();
		if (rowIdx < 0) return;
		comLib.closePopupCall($p, scwin.popupParam, true, dltClsCdList.getRowJSON(rowIdx));
	};

	/**
	 * 그리드에서 사용자 선택을 하면 메인으로 전달한다.
	 * @param <Int> row
	 * @param <Int> col
	 * @return
	 */
	scwin.grdClsCdList_oncelldblclick = function(row, col) {
		scwin.btnCnfirm_onclick();
	};
]]></script>
	</head>
	<body>
		<xf:group class="popup-wrap">
			<xf:group id="grpInqire" class="search-box">
				<xf:group class="list">
					<xf:group class="w2tb" tagname="table">
						<w2:attributes>
							<w2:summary></w2:summary>
						</w2:attributes>
						<xf:group tagname="caption"></xf:group>
						<xf:group tagname="colgroup">
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
						</xf:group>
						<xf:group tagname="tr">
							<xf:group class="w2tb_th cw4" tagname="th">
								<w2:attributes>
									<w2:scope>row</w2:scope>
								</w2:attributes>
								<w2:span label="분류코드"></w2:span>
							</xf:group>
							<xf:group class="w2tb_td cw4" tagname="td">
								<xf:input id="ibxCmmnCdNm" ref="data:dmaInqireParam.cmmnCdNm">
								</xf:input>
							</xf:group>
							<xf:group class="w2tb_th cw2" tagname="th">
								<w2:attributes>
									<w2:scope>row</w2:scope>
								</w2:attributes>
								<w2:span label="사용자정의" style="display:none;">
								</w2:span>
							</xf:group>
							<xf:group class="w2tb_td cw3" tagname="td">
								<xf:input id="ibxUsrDfnEtcVu" ref="data:dmaInqireParam.usrDfnEtcVu" style="display:none;">
								</xf:input>
							</xf:group>
							<xf:group class="w2tb_th cw2" style="display:none;" tagname="th">
								사용여부
							</xf:group>
							<xf:group class="w2tb_td cw3" tagname="td">
								<xf:select1 id="radUseYn" appearance="full" cols="2" ref="data:dmaInqireParam.useYn" selectedIndex="0" style="display:none;"
									renderType="radiogroup">
									<xf:choices>
										<xf:item>
											<xf:label><![CDATA[Y]]></xf:label>
											<xf:value><![CDATA[Y]]></xf:value>
										</xf:item>
										<xf:item>
											<xf:label><![CDATA[N]]></xf:label>
											<xf:value><![CDATA[N]]></xf:value>
										</xf:item>
									</xf:choices>
								</xf:select1>
							</xf:group>
						</xf:group>
					</xf:group>
				</xf:group>
				<xf:group class="btn-group">
					<w2:anchor id="btnInqire" class="fa fa-search btn_sh" ev:onclick="scwin.btnInqire_onclick" outerDiv="false" userData1="Q">
						<xf:label><![CDATA[조회]]></xf:label>
					</w2:anchor>
				</xf:group>
			</xf:group>
			<xf:group class="content-area">
				<xf:group class="con-box">
					<xf:group class="list-box box">
						<xf:group class="title-group">
							<xf:group tagname="h4">
								<w2:span label="분류코드"></w2:span>
								<w2:span id="txtCnt" class="title-num" displayFormat="###,###, ###" label="0">
								</w2:span>
							</xf:group>
						</xf:group>
						<w2:gridView id="grdClsCdList" dataList="dltClsCdList" fixedColumnWithHidden="true" ignoreCellClick="false"
							ignoreToggleOnDisabled="false" readOnly="true" rowNumHeaderValue="No" rowNumVisible="true" rowNumWidth="25" scrollByColumn="false"
							scrollByColumnAdaptive="false" sortable="true" summaryAuto="false" tooltipDisplay="true" useShiftKey="true" visibleRowNum="6"
							focusMode="row" ev:oncelldblclick="scwin.grdClsCdList_oncelldblclick">
							<w2:header>
								<w2:row>
									<w2:column id="hCmmnCd" inputType="text" style="height:20px;" value="분류코드" width="120">
									</w2:column>
									<w2:column id="hCmmnCdNm" inputType="text" style="height:20px;" value="분류코드명" width="150">
									</w2:column>
									<w2:column id="hCmmnCdDc" inputType="text" style="height:20px;" value="clsCdDc" width="*">
									</w2:column>
								</w2:row>
							</w2:header>
							<w2:gBody>
								<w2:row>
									<w2:column id="clsCd" inputType="text" style="height:20px" width="120">
									</w2:column>
									<w2:column id="clsCdNm" inputType="text" style="height:20px" width="150">
									</w2:column>
									<w2:column id="clsCdDc" inputType="text" style="height:20px" width="*">
									</w2:column>
								</w2:row>
							</w2:gBody>
						</w2:gridView>
					</xf:group>
				</xf:group>
			</xf:group>
			<xf:group class="footer">
				<xf:group class="btn-group">
					<w2:anchor id="btnCnfirm" ev:onclick="scwin.btnCnfirm_onclick" outerDiv="false">
						<xf:label><![CDATA[확인]]></xf:label>
					</w2:anchor>
				</xf:group>
			</xf:group>
		</xf:group>
	</body>
</html>