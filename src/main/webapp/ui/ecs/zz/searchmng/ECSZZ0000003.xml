<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet href="/resources/css/content.css" type="text/css"?>
<?xml-stylesheet href="/resources/css/content-layout.css" type="text/css"?>
<?xml-stylesheet href="/resources/css/animate.css" type="text/css"?>
<?xml-stylesheet href="/resources/css/font-awesome.min.css" type="text/css"?>
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:w2="http://www.inswave.com/websquare"
	xmlns:xf="http://www.w3.org/2002/xforms">
	<head>
		<!--
			========================================================================
			* 소스명 : ECSZZ0000003.xml
			* 설 명 : 메뉴검색하기 위한 프로그램
			* 작성일 : 2023.11.30
			* 담당자 : Soltech 위해서
			* << 개정이력 >>
			* 수정일 수정자 수정내용
			* 2023.11.30 Soltech 위해서 최초 작성
			========================================================================
		-->
		<w2:type>DEFAULT</w2:type>
		<w2:buildDate />
		<xf:model>
			<xf:instance>
				<data xmlns="" />
			</xf:instance>
			<w2:dataCollection baseNode="map">
				<w2:dataMap id="dmaInqireParam" baseNode="map">
					<w2:keyInfo>
						<w2:key id="menuSysDivCd" dataType="text" name="메뉴시스템구분코드">
						</w2:key>
						<w2:key id="menuId" dataType="text" name="메뉴ID">
						</w2:key>
						<w2:key id="menuNm" dataType="text" name="메뉴명">
						</w2:key>
					</w2:keyInfo>
				</w2:dataMap>
				<w2:dataList id="dltMenuList" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<w2:column id="menuSysDivCd" dataType="text" name="메뉴시스템코드">
						</w2:column>
						<w2:column id="menuId" dataType="text" name="메뉴코드">
						</w2:column>
						<w2:column id="menuNm" dataType="text" name="메뉴명">
						</w2:column>
						<w2:column id="menuOrdr" dataType="text" name="메뉴정렬순서">
						</w2:column>
						<w2:column id="menuLvl" dataType="text" name="메뉴레벨">
						</w2:column>
					</w2:columnInfo>
					<w2:data use="false">
					</w2:data>
				</w2:dataList>
				<w2:dataList id="dltUpperMenuList" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<w2:column id="menuSysDivCd" dataType="text" name="메뉴시스템구분">
						</w2:column>
						<w2:column id="menuId" dataType="text" name="메뉴코드">
						</w2:column>
						<w2:column id="menuNm" dataType="text" name="메뉴명">
						</w2:column>
					</w2:columnInfo>
				</w2:dataList>
			</w2:dataCollection>
			<w2:workflowCollection></w2:workflowCollection>
		</xf:model>
		<script lazy="false" type="text/javascript"><![CDATA[
	/**
	 * 메뉴검색 화면 초기화 작업을 수행한다.
	 * @param
	 * @return
	 */
	scwin.popupParam;
	scwin.initScreen = function() {
		scwin.popupParam=comLib.getPopupParam($p,["sysDivCd"]);
		// 화면초기화 공통 함수 호출
		comLib.initForm($p, scwin.popupParam.popupID);

		// 공통코드 조회
		scwin.setCommonCode();

		// 화면 초기로딩시 선택권한 활성화(파라미터로 넘어온 값이 있으면 비활성화
		sbxUpperMenuSysDivCd.setDisabled(false);

		// 전달받은 메뉴시스템구분코드 설정
		if (scwin.popupParam.sysDivCd) {
			sbxUpperMenuSysDivCd.setDisabled(true);
		} 

		// dataMap, dataList을 초기화
		dltMenuList.removeAll();

		// 초기화 한 dataMap에 메뉴시스템구분코드를 설정
		if (scwin.popupParam.sysDivCd) {
			dmaInqireParam.set("menuSysDivCd", scwin.popupParam.sysDivCd);
		}

		// 메뉴 조회
		comLib.setEnterKeyEvent(grpInqire, scwin.btnInqire_onclick);
		scwin.btnInqire_onclick();
	};

	/**
	 * 공통 코드 조회
	 * @param
	 * @return
	 */
	scwin.setCommonCode = function() {
		var options = [{ clsCd : "SCM_0000", suffixNm : "", object : ["sbxUpperMenuSysDivCd"]}];
		comLib.setCommonCodeSync($p, options);
	};

	/**
	 * 메뉴정보를 조회한다.
	 * @param
	 * @return
	 */
	scwin.btnInqire_onclick = function() {
		var requestData = {};
		requestData.dmaInqireParam = dmaInqireParam.getJSON();

		var option = {action : "sc/cmmncd/retrieveMenu.do",
			reqData : requestData,
			resData : dltMenuList,
			success : "scwin.inqireCallback",
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	/**
	 * 메뉴정보 조회후 콜백 로직을 수행한다.
	 * @param <Object> resBody
	 * @return
	 */
	scwin.inqireCallback = function(resBody) {
		if (dltMenuList.getRowCount() > 0) {
		txtCnt.setValue(dltMenuList.getRowCount());
		} else {
			// 조회된 {0}가 없습니다.
			comLib.alert($p, utilLib.getMessage("SCM.INFO.00322", "메뉴"));
		}
		ibxMenuNm.focus();
	};

	/**
	 * 선택된 메뉴정보를 반환한다.
	 * @param
	 * @return
	 */
	scwin.btnCnfirm_onclick = function() {
		var rowIdx = twMenuList.getSelectedIndex();
		if (rowIdx < 0) return;
		comLib.closePopupCall($p, scwin.popupParam, true, dltMenuList.getRowJSON(rowIdx));
	};

	/**
	 * 트리뷰에서 사용자 선택을 하면 메인으로 전달한다.
	 * @param <Int> row
	 * @param <Int> col
	 * @return	
	 */
	scwin.twMenuList_ondblclick = function() {
		scwin.btnCnfirm_onclick();
	};
]]></script>
	</head>
	<body>
		<xf:group class="popup-wrap">
			<xf:group id="grpInqire" class="search-box">
				<xf:group class="list">
					<xf:group class="w2tb" tagname="table">
						<w2:attributes>
							<w2:summary></w2:summary>
						</w2:attributes>
						<xf:group tagname="caption"></xf:group>
						<xf:group tagname="colgroup">
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
						</xf:group>
						<xf:group tagname="tr">
							<xf:group class="w2tb_th cw2" tagname="th">
								<w2:attributes>
									<w2:scope>row</w2:scope>
								</w2:attributes>
								<w2:span label="시스템구분"></w2:span>
							</xf:group>
							<xf:group class="w2tb_td cw3" tagname="td">
								<xf:select1 id="sbxUpperMenuSysDivCd" appearance="minimal" chooseOption="true" chooseOptionLabel="전체" direction="auto"
									disabled="false" disabledClass="w2selectbox_disabled" displayMode="label" optionOrder="false" ref="data:dmaInqireParam.menuSysDivCd"
									selectedData="true" submenuSize="auto">
									<xf:choices>
										<xf:itemset>
											<xf:label></xf:label>
											<xf:value></xf:value>
										</xf:itemset>
									</xf:choices>
								</xf:select1>
							</xf:group>
							<xf:group class="w2tb_th cw2" tagname="th">
								<w2:attributes>
									<w2:scope>row</w2:scope>
								</w2:attributes>
								<w2:span label="메뉴명">
								</w2:span>
							</xf:group>
							<xf:group class="w2tb_td cw3" tagname="td">
								<xf:input id="ibxMenuNm" ref="data:dmaInqireParam.menuNm">
								</xf:input>
							</xf:group>
						</xf:group>
					</xf:group>
				</xf:group>
				<xf:group class="btn-group">
					<w2:anchor id="btnInqire" class="fa fa-search btn_sh" ev:onclick="scwin.btnInqire_onclick" outerDiv="false" userData1="Q">
						<xf:label><![CDATA[조회]]></xf:label>
					</w2:anchor>
				</xf:group>
			</xf:group>
			<xf:group class="content-area">
				<xf:group class="con-box">
					<xf:group class="list-box box">
						<xf:group class="title-group">
							<xf:group tagname="h4">
								<w2:span label="메뉴"></w2:span>
								<w2:span id="txtCnt" class="title-num" displayFormat="###,###, ###" label="0"></w2:span>
							</xf:group>
						</xf:group>
						<w2:treeview id="twMenuList" dataType="listed" tooltipGroupClass="false" style="height : 310px;" ev:ondblclick="scwin.twMenuList_ondblclick">
							<w2:itemset nodeset="data:dltMenuList">
								<w2:label ref="menuNm"></w2:label>
								<w2:value ref="menuId"></w2:value>
								<w2:depth ref="menuLvl"></w2:depth>
								<w2:folder></w2:folder>
								<w2:checkbox></w2:checkbox>
								<w2:checkboxDisabled></w2:checkboxDisabled>
								<w2:image></w2:image>
								<w2:iconImage></w2:iconImage>
								<w2:selectedImage></w2:selectedImage>
								<w2:expandedImage></w2:expandedImage>
								<w2:leafImage></w2:leafImage>
							</w2:itemset>
						</w2:treeview>
					</xf:group>
				</xf:group>
			</xf:group>
			<xf:group class="footer">
				<xf:group class="btn-group">
					<w2:anchor id="btnCnfirm" ev:onclick="scwin.btnCnfirm_onclick" outerDiv="false">
						<xf:label><![CDATA[확인]]></xf:label>
					</w2:anchor>
				</xf:group>
			</xf:group>
		</xf:group>
	</body>
</html>