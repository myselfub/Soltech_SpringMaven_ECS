<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet href="/resources/css/content.css" type="text/css"?>
<?xml-stylesheet href="/resources/css/content-layout.css" type="text/css"?>
<?xml-stylesheet href="/resources/css/animate.css" type="text/css"?>
<?xml-stylesheet href="/resources/css/font-awesome.min.css" type="text/css"?>
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:w2="http://www.inswave.com/websquare"
	xmlns:xf="http://www.w3.org/2002/xforms">
	<head>
		<!--
			========================================================================
			* 소스명 : ECSZZ0000004.xml
			* 설 명 : 화면검색하기 위한 프로그램
			* 작성일 : 2023.11.30
			* 담당자 : Soltech 위해서
			* << 개정이력 >>
			* 수정일 수정자 수정내용
			* 2023.11.30 Soltech 위해서 최초 작성
			========================================================================
		-->
		<w2:type>DEFAULT</w2:type>
		<w2:buildDate />
		<xf:model>
			<xf:instance>
				<data xmlns="" />
			</xf:instance>
			<w2:dataCollection baseNode="map">
				<w2:dataMap id="dmaInqireParam" baseNode="map">
					<w2:keyInfo>
						<w2:key id="intnSysDivCd" dataType="text" name="시스템구분코드">
						</w2:key>
						<w2:key id="scrinNm" dataType="text" name="화면명">
						</w2:key>
						<w2:key id="useYn" dataType="text" name="사용여부">
						</w2:key>
					</w2:keyInfo>
				</w2:dataMap>
				<w2:dataList id="dltScrinList" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<w2:column id="scrinId" dataType="text" name="화면ID"></w2:column>
						<w2:column id="intnSysDivCd" dataType="text" name="시스템구분코드"></w2:column>
						<w2:column id="intnSysDivNm" name="시스템구분명" dataType="text"></w2:column>
						<w2:column id="scrinNm" dataType="text" name="화면명"></w2:column>
						<w2:column id="scrinUrl" dataType="text" name="화면URL"></w2:column>
						<w2:column id="scrinDc" dataType="text" name="화면설명"></w2:column>
						<w2:column id="useYn" dataType="text" name="사용여부"></w2:column>
					</w2:columnInfo>
					<w2:data use="false"></w2:data>
				</w2:dataList>
			</w2:dataCollection>
			<w2:workflowCollection></w2:workflowCollection>
		</xf:model>
		<script lazy="false" type="text/javascript"><![CDATA[
	/**
	 * 화면등록 정보 화면 초기화 작업을 수행한다.
	 * @param
	 * @return
	 */
	scwin.popupParam;
	scwin.initScreen = function() {
		scwin.popupParam=comLib.getPopupParam($p,["sysDivCd"]);
		//화면초기화 공통 함수 호출
		comLib.initForm($p, scwin.popupParam.popupID);

		// dataMap, dataList을 초기화
		dltScrinList.removeAll();

		// 초기화 한 dataMap에 공통분류코드를 설정
		if (scwin.popupParam.sysDivCd) {
			dmaInqireParam.set("intnSysDivCd", scwin.popupParam.sysDivCd);
		}

		// 화면등록정보 조회
		comLib.setEnterKeyEvent(grpInqire, scwin.btnInqire_onclick);
		scwin.btnInqire_onclick();
	};

	/**
	 * 화면등록정보를 조회한다.
	 * @param
	 * @return
	 */
	scwin.btnInqire_onclick = function() {
		var requestData = {};
		requestData.dmaInqireParam = dmaInqireParam.getJSON();

		var option = {action : "zz/authmng/retrieveScrin.do",
			reqData : requestData,
			resData : dltScrinList,
			success : "scwin.inqireCallback",
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	/**
	 * 화면등록정보 조회후 콜백 로직을 수행한다.
	 * @param <Object> resBody
	 * @return
	 */
	scwin.inqireCallback = function(resBody) {
		if (dltScrinList.getRowCount() > 0) {	
			txt_Cnt.setValue(dltScrinList.getRowCount());
		} else {
			// 조회된 {0}가 없습니다. 
			comLib.alert($p, utilLib.getMessage("SCM.INFO.00322", "화면"));
		}
		ibxScrinNm.focus();
	};

	/**
	 * 선택된 화면정보를 반환한다.
	 * @param
	 * @return
	 */
	scwin.btnCnfirm_onclick = function() {
		var rowIdx = grdScrinList.getFocusedRowIndex();

		if (rowIdx < 0) return;
		comLib.closePopupCall($p, scwin.popupParam, true, dltScrinList.getRowJSON(rowIdx));
	};

	/**
	 * 그리드에서 사용자 선택을 하면 메인으로 전달한다.
	 * @param <Int> row
	 * @param <Int> col
	 * @return
	 */
	scwin.grdScrinList_oncelldblclick = function(row, col) {
		scwin.btnCnfirm_onclick();
	};
]]></script>
	</head>
	<body>
		<xf:group class="popup-wrap">
			<xf:group id="grpInqire" class="search-box">
				<xf:group class="list">
					<xf:group class="w2tb" tagname="table">
						<w2:attributes>
							<w2:summary></w2:summary>
						</w2:attributes>
						<xf:group tagname="caption"></xf:group>
						<xf:group tagname="colgroup">
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
						</xf:group>
						<xf:group tagname="tr">
							<xf:group class="w2tb_th cw2" tagname="th">
								<w2:attributes>
									<w2:scope>row</w2:scope>
								</w2:attributes>
								<w2:span label="화면명"></w2:span>
							</xf:group>
							<xf:group class="w2tb_td cw3" tagname="td">
								<xf:input id="ibxScrinNm" ref="data:dmaInqireParam.scrinNm">
								</xf:input>
							</xf:group>
							<xf:group class="w2tb_th cw2" tagname="th">
								사용여부
							</xf:group>
							<xf:group class="w2tb_td cw3" tagname="td">
								<xf:select1 id="radUseYn" appearance="full" cols="2" ref="data:dmaInqireParam.useYn" selectedIndex="0" renderType="radiogroup">
									<xf:choices>
										<xf:item>
											<xf:label><![CDATA[Y]]></xf:label>
											<xf:value><![CDATA[Y]]></xf:value>
										</xf:item>
										<xf:item>
											<xf:label><![CDATA[N]]></xf:label>
											<xf:value><![CDATA[N]]></xf:value>
										</xf:item>
									</xf:choices>
								</xf:select1>
							</xf:group>
						</xf:group>
					</xf:group>
				</xf:group>
				<xf:group class="btn-group">
					<w2:anchor id="btnInqire" class="fa fa-search btn_sh" ev:onclick="scwin.btnInqire_onclick" outerDiv="false" userData1="Q">
						<xf:label><![CDATA[조회]]></xf:label>
					</w2:anchor>
				</xf:group>
			</xf:group>
			<xf:group class="content-area">
				<xf:group class="con-box">
					<xf:group class="list-box box">
						<xf:group class="title-group">
							<xf:group tagname="h4">
								<w2:span label="화면"></w2:span>
								<w2:span id="txt_Cnt" class="title-num" displayFormat="###,###, ###" label="0">
								</w2:span>
							</xf:group>
						</xf:group>
						<w2:gridView id="grdScrinList" dataList="dltScrinList" fixedColumnWithHidden="true" ignoreCellClick="false"
							ignoreToggleOnDisabled="false" readOnly="true" rowNumHeaderValue="No" rowNumVisible="true" rowNumWidth="25" scrollByColumn="false"
							scrollByColumnAdaptive="false" sortable="true" summaryAuto="false" tooltipDisplay="true" useShiftKey="true" visibleRowNum="7"
							focusMode="row" fixedColumn="3" ev:oncelldblclick="scwin.grdScrinList_oncelldblclick">
							<w2:header>
								<w2:row>
									<w2:column id="hIntnSysDivNm" inputType="text" style="height:20px;" value="시스템구분" width="70">
									</w2:column>
									<w2:column id="hScrinId" inputType="text" style="height:20px;" value="화면ID" width="70" hidden="true" textAlign="center">
									</w2:column>
									<w2:column id="hScrinNm" inputType="text" style="height:20px;" value="화면명" width="100" textAlign="center">
									</w2:column>
									<w2:column id="hScrinUrl" width="200" inputType="text" style="height:20px;" value="화면URL" textAlign="center">
									</w2:column>
									<w2:column id="hScrinDc" width="*" inputType="text" style="height:20px;" value="화면설명" textAlign="center">
									</w2:column>
									<w2:column id="hUseYn" width="70" inputType="text" style="height:20px;" value="사용여부" textAlign="center">
									</w2:column>
								</w2:row>
							</w2:header>
							<w2:gBody>
								<w2:row>
									<w2:column id="intnSysDivNm" inputType="text" style="height:20px" width="70">
									</w2:column>
									<w2:column id="scrinId" inputType="text" style="height:20px" width="70" hidden="true">
									</w2:column>
									<w2:column id="scrinNm" inputType="text" style="height:20px" width="100" textAlign="left">
									</w2:column>
									<w2:column id="scrinUrl" width="200" inputType="text" style="height:20px" textAlign="left">
									</w2:column>
									<w2:column id="scrinDc" width="*" inputType="text" style="height:20px" textAlign="left">
									</w2:column>
									<w2:column id="useYn" width="70" inputType="text" style="height:20px">
									</w2:column>
								</w2:row>
							</w2:gBody>
						</w2:gridView>
					</xf:group>
				</xf:group>
			</xf:group>
			<xf:group class="footer">
				<xf:group class="btn-group">
					<w2:anchor id="btnCnfirm" ev:onclick="scwin.btnCnfirm_onclick" outerDiv="false">
						<xf:label><![CDATA[확인]]></xf:label>
					</w2:anchor>
				</xf:group>
			</xf:group>
		</xf:group>
	</body>
</html>