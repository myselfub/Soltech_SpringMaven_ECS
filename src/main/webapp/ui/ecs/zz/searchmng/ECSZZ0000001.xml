<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet href="/resources/css/content.css" type="text/css"?>
<?xml-stylesheet href="/resources/css/content-layout.css" type="text/css"?>
<?xml-stylesheet href="/resources/css/animate.css" type="text/css"?>
<?xml-stylesheet href="/resources/css/font-awesome.min.css" type="text/css"?>
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:w2="http://www.inswave.com/websquare"
	xmlns:xf="http://www.w3.org/2002/xforms">
	<head>
		<!--
			========================================================================
			* 소스명 : ECSZZ0000001.xml
			* 설 명 : 임직원검색을 위한 프로그램
			* 작성일 : 2023.11.29
			* 담당자 : Soltech 위해서
			* << 개정이력 >>
			* 수정일 수정자 수정내용
			* 2023.11.29 Soltech 위해서 최초 작성
			========================================================================
		-->
		<w2:type>DEFAULT</w2:type>
		<w2:buildDate />
		<xf:model>
			<xf:instance>
				<data xmlns="" />
			</xf:instance>
			<w2:dataCollection baseNode="map">
				<w2:dataList id="dltUsrList" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<w2:column id="usrDeptCd" name="부서코드" dataType="text"></w2:column>
						<w2:column id="usrDeptNm" name="부서명" dataType="text"></w2:column>
						<w2:column id="usrEmpno" dataType="text" name="사번"></w2:column>
						<w2:column id="usrId" name="사용자ID" dataType="text"></w2:column>
						<w2:column id="usrNm" name="사용자명" dataType="text"></w2:column>
						<w2:column id="usrOfcpsCd" name="직위코드" dataType="text"></w2:column>
						<w2:column id="usrOfcpsNm" name="직위명" dataType="text"></w2:column>
						<w2:column id="usrJgrdCd" name="직급코드" dataType="text"></w2:column>
						<w2:column id="usrJgrdNm" name="직급명" dataType="text"></w2:column>
						<w2:column id="usrLxtnTelno" name="내선전화번호" dataType="text"></w2:column>
						<w2:column id="usrEmail" name="이메일" dataType="text"></w2:column>
						<w2:column id="useYn" name="사용여부" dataType="text"></w2:column>
					</w2:columnInfo>
					<w2:data use="false"></w2:data>
				</w2:dataList>
				<w2:dataMap id="dmaInqireParam" baseNode="map">
					<w2:keyInfo>
						<w2:key id="usrDeptCd" name="부서코드" dataType="text"></w2:key>
						<w2:key id="usrNm" name="사용자명" dataType="text"></w2:key>
					</w2:keyInfo>
					<w2:data use="false"></w2:data>
				</w2:dataMap>
				<w2:dataList id="dltDeptCd" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<w2:column id="objid" name="부서코드" dataType="text"></w2:column>
						<w2:column id="stext" name="부서명" dataType="text"></w2:column>
					</w2:columnInfo>
				</w2:dataList>
			</w2:dataCollection>
		</xf:model>
		<script lazy="false" type="text/javascript"><![CDATA[
	/**
	 * 공통코드 정보 화면 초기화 작업을 수행한다.
	 * @param
	 * @return
	 */
	scwin.popupParam;
	scwin.initScreen = function() {
		scwin.popupParam=comLib.getPopupParam($p,["searchUsrNm"]);
		// 화면초기화 공통 함수 호출
		comLib.initForm($p, scwin.popupParam.popupID);

		// 부서코드 조회
		scwin.setDeptCd();	

		comLib.setEnterKeyEvent(grpInqire, scwin.btnInqire_onclick);
	};

	/**
	 * 부서코드 조회
	 * @param
	 * @return	
	 */
	scwin.setDeptCd = function() {
		var requestData = {};

		var option = {action : "sc/cmmncd/retrieveDeptInqire.do",
			reqData : requestData,
			resData : dltDeptCd,
			success : "scwin.setDeptCdCallback",
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	/**
	 * 부서코드 조회
	 * @param
	 * @return
	 */
	scwin.setDeptCdCallback = function() {
		if (scwin.popupParam.searchUsrNm != null && scwin.popupParam.searchUsrNm != "") {
			atcUsrDeptCd.setValue("");
			ibxUsrNm.setValue(scwin.popupParam.searchUsrNm);
		} else {
			atcUsrDeptCd.setValue(comLib.getUsrDeptCd());
		}
		scwin.btnInqire_onclick();
	};

	/**
	 * 사용자 정보를 조회한다.
	 * @param
	 * @return
	 */
	scwin.btnInqire_onclick = function() {
		var requestData = {};
		requestData.dmaInqireParam = dmaInqireParam.getJSON();

		var option = {action : "sc/cmmncd/retrieveUsrInqire.do",
		reqData : requestData,
		resData : dltUsrList,
		success : "scwin.inqireCallback",
		isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	/**
	 * 공통코드 조회후 콜백 로직을 수행한다.
	 * @param <Object> resBody
	 * @return
	 */
	scwin.inqireCallback = function(resBody) {
		if (dltUsrList.getRowCount() > 0) {
			// console.log("조회된 데이터는 총 " + dltUsrList.getRowCount() + " 건 입니다.");
			txtCnt.setValue(dltUsrList.getRowCount());
		} else {
			txtCnt.setValue("0");
			// 조회된 {0}가 없습니다.
			comLib.alert($p, utilLib.getMessage("SCM.INFO.00322", "사용자"));
		}

		ibxUsrNm.focus();
	};

	/**
	 * 사용자 선택 정보를 메인으로 전달한다.
	 * @param
	 * @return
	 */
	scwin.btnCnfirm_onclick = function() {
		var rowIdx = grdUsrList.getFocusedRowIndex();
		var colIdx = grdUsrList.getFocusedColumnIndex();

		if (rowIdx < 0) return;
		comLib.closePopupCall($p,scwin.popupParam,true,dltUsrList.getRowJSON(rowIdx));
	};

	/**
	 * 그리드에서 사용자 선택을 하면 메인으로 전달한다.
	 * @param <Int> row
	 * @param <Int> col
	 * @return
	 */
	scwin.grdUsrList_oncelldblclick = function(row,col) {
		scwin.btnCnfirm_onclick();
	};
		]]>
		</script>
	</head>
	<body>
		<xf:group class="popup-wrap">
			<xf:group id="grpInqire" class="search-box">
				<xf:group class="list">
					<xf:group class="w2tb" tagname="table">
						<w2:attributes>
							<w2:summary></w2:summary>
						</w2:attributes>
						<xf:group tagname="caption"></xf:group>
						<xf:group tagname="colgroup">
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
						</xf:group>
						<xf:group tagname="tr">
							<xf:group class="w2tb_th cw2" tagname="th">
								<w2:attributes>
									<w2:scope>row</w2:scope>
								</w2:attributes>
								<w2:span label="부서"></w2:span>
							</xf:group>
							<xf:group class="w2tb_td cw5" tagname="td">
								<w2:autoComplete id="atcUsrDeptCd" submenuSize="auto" search="contain" editType="select" chooseOption="true"
									useKeywordHighlight="false" visibleRowNum="5" ref="data:dmaInqireParam.usrDeptCd" chooseOptionLabel="- 전체 -">
									<w2:choices>
										<w2:itemset nodeset="data:dltDeptCd">
											<w2:label ref="stext"></w2:label>
											<w2:value ref="objid"></w2:value>
										</w2:itemset>
									</w2:choices>
								</w2:autoComplete>
							</xf:group>
							<xf:group class="w2tb_th cw2" tagname="th">
								<w2:attributes>
									<w2:scope>row</w2:scope>
								</w2:attributes>
								<w2:span label="성명">
								</w2:span>
							</xf:group>
							<xf:group class="w2tb_td cw3" tagname="td">
								<xf:input id="ibxUsrNm" ref="data:dmaInqireParam.usrNm">
								</xf:input>
							</xf:group>
						</xf:group>
					</xf:group>
				</xf:group>
				<xf:group class="btn-group">
					<w2:anchor id="btnInqire" class="fa fa-search btn_sh" ev:onclick="scwin.btnInqire_onclick" outerDiv="false" userData1="Q">
						<xf:label><![CDATA[조회]]></xf:label>
					</w2:anchor>
				</xf:group>
			</xf:group>
			<xf:group class="content-area">
				<xf:group class="con-box">
					<xf:group class="list-box box">
						<xf:group class="title-group">
							<xf:group tagname="h4">
								<w2:span label="직원명단"></w2:span>
								<w2:span id="txtCnt" class="title-num" displayFormat="###,###, ###" label="0">
								</w2:span>
							</xf:group>
						</xf:group>
						<w2:gridView id="grdUsrList" autoFit="allColumn" dataList="dltUsrList" fixedColumnWithHidden="true" ignoreCellClick="false"
							ignoreToggleOnDisabled="false" rowNumHeaderValue="No" rowNumVisible="true" scrollByColumn="false" scrollByColumnAdaptive="false"
							style="height: 150px;" summaryAuto="false" useFilterList="false" useShiftKey="true" visibleRowNum="7" readOnly="true" sortable="true"
							tooltipDisplay="true" ev:oncelldblclick="scwin.grdUsrList_oncelldblclick">
							<w2:header>
								<w2:row>
									<w2:column id="hUsrDeptCd" inputType="text" style="height:40px;" value="부서" width="70">
									</w2:column>
									<w2:column id="hUsrOfcpsCd" inputType="text" style="height:40px;" value="직위" width="70">
									</w2:column>
									<w2:column id="hUsrClsfCd" width="70" inputType="text" style="height:40px;" value="직급">
									</w2:column>
									<w2:column id="hUsrNm" inputType="text" style="height:40px;" value="성명" width="70">
									</w2:column>
								</w2:row>
							</w2:header>
							<w2:gBody>
								<w2:row>
									<w2:column id="usrDeptNm" inputType="text" style="height:34px;" width="70"></w2:column>
									<w2:column id="usrOfcpsNm" inputType="text" style="height:34px;" width="70"></w2:column>
									<w2:column id="usrJgrdNm" width="70" inputType="text" style="height:34px;"></w2:column>
									<w2:column id="usrNm" inputType="text" style="height:34px;" width="70"></w2:column>
								</w2:row>
							</w2:gBody>
						</w2:gridView>
					</xf:group>
				</xf:group>
			</xf:group>
			<xf:group class="footer">
				<xf:group class="btn-group">
					<w2:anchor id="btnCnfirm" ev:onclick="scwin.btnCnfirm_onclick" outerDiv="false">
						<xf:label><![CDATA[확인]]></xf:label>
					</w2:anchor>
				</xf:group>
			</xf:group>
		</xf:group>
	</body>
</html>