						<w2:key id="endDt" name="검색종료일자" dataType="text"></w2:key>
						<w2:key id="usrId" name="사용자ID" dataType="text"></w2:key>
						<w2:key id="usrNm" name="사용자명" dataType="text"></w2:key>
