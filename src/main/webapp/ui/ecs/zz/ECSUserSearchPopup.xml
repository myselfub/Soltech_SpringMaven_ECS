<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet href="/resources/css/modal.css" type="text/css"?>
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:w2="http://www.inswave.com/websquare"
	xmlns:xf="http://www.w3.org/2002/xforms">
	<head>
		<!--
			========================================================================
			* 소스명 : ECSPB1400000.xml
			* 설 명 : 에너지 계획/건설 등록_전자문서등록(프로젝트문서)
			* 작성일 : 2023.06.12
			* 담당자: Soltech 위해서
			* << 개정이력 >>
			* 수정일 수정자 수정내용
			* 2023.06.12 Soltech 위해서 최초 작성
			========================================================================
		-->
		<w2:type>DEFAULT</w2:type>
		<w2:buildDate />
		<xf:model>
			<xf:instance>
				<data xmlns="" />
			</xf:instance>
			<w2:dataCollection baseNode="map">
				<w2:dataMap id="dmaSearchParam" baseNode="map">
					<w2:keyInfo>
						<w2:key id="dept" dataType="text" name="부서"></w2:key>
						<w2:key id="korname" dataType="text" name="성명"></w2:key>
					</w2:keyInfo>
				</w2:dataMap>
				<w2:dataList id="dltAutoCondition1" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<w2:column id="clsCd" dataType="text" name="대분류 코드"></w2:column>
						<w2:column id="clsCdNm" dataType="text" name="대분류 이름"></w2:column>
						<w2:column id="cmmnCd" dataType="text" name="소분류 코드"></w2:column>
						<w2:column id="cmmnCdNm" dataType="text" name="소분류 이름"></w2:column>
						<w2:column id="upperCmmnCd" dataType="text" name="상위 소분류 코드1"></w2:column>
						<w2:column id="upperCmmnCdNm" dataType="text" name="상위 소분류 이름1"></w2:column>
						<w2:column id="upperCmmnCd2" dataType="text" name="상위 소분류 코드2"></w2:column>
						<w2:column id="upperCmmnCdNm2" dataType="text" name="상위 소분류 이름2"></w2:column>
						<w2:column id="upperCmmnCd3" dataType="text" name="상위 소분류 코드3"></w2:column>
						<w2:column id="upperCmmnCdNm3" dataType="text" name="상위 소분류 이름3"></w2:column>
					</w2:columnInfo>
				</w2:dataList>
				<w2:dataList id="dltUserList" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<w2:column id="dept" dataType="text" name="부서"></w2:column>
						<w2:column id="posit" dataType="text" name="지위"></w2:column>
						<w2:column id="grade" dataType="text" name="직급"></w2:column>
						<w2:column id="korname" dataType="text" name="성명"></w2:column>
						<w2:column id="empno" dataType="text" name="사원번호"></w2:column>
					</w2:columnInfo>
				</w2:dataList>
			</w2:dataCollection>
			<w2:workflowCollection></w2:workflowCollection>
		</xf:model>
		<script lazy="false" type="text/javascript"><![CDATA[
	scwin.initData = {
		"valInfo" : [
			{id : "korname", maxByteLength : 100, mandatory : true}
		]
	};

	scwin.onpageunload = function() {
		scwin.initData.parent.$p.getComponentById(scwin.initData.parent.$p.getPopupId()).setDisabled(false);
		scwin.initData.parent.$p.getComponentById(scwin.initData.parent.$p.getFrameId()).setDisabled(false);
	};

	/**
	 * 화면 초기화에 필요한 로직을 수행한다.
	 * @param
	 * @return
	 */
	scwin.initScreen = function() {
		scwin.initData.parent = $p.parent();
		// 부모창 <input> id를 param(this.id)으로 가져옴 
		scwin.param = JSON.parse($p.getPopupParam());
		// 화면초기화 공통 함수 호출
		// comLib.initForm($p, "ECSUserSearchPopup");
		// 부서 조회조건 조회
		scwin.initDeptSearch();
		// 데이터 조회
		// scwin.btnInqire_onclick();
	};

	/**
	 * 부서 조회조건 조회한다.
	 * @param
	 * @return dltAutoCondition1
	 */
	scwin.initDeptSearch = function() {
		var option = {
			action : "zz/cmmn/retrieve-hrm-dept.do",
			method : "get",
			resData : dltAutoCondition1,
			success : "scwin.initDeptSearchCallback",
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	}

	/**
	 * 부서 조회조건 CallBack 실행한다.
	 * @param <Object> resBody
	 * @return
	 */
	scwin.initDeptSearchCallback = function() {
		scwin.initSearchParam();
		// scwin.btnInqire_onclick();
	}

	/**
	 * 조회조건 초기화에 필요한 로직을 수행한다.
	 * @param
	 * @return
	 */
	scwin.initSearchParam = function() {
		dmaSearchParam.set("dept", "");
		dmaSearchParam.set("korname", "");
	};

	/**
	 * 조회조건에 맞게 data를 조회한다.
	 * @param
	 * @return
	 */
	scwin.btnInqire_onclick = function() {
		ecsLib.validateInput(grpInqire, scwin.initData.valInfo, true);
		if(dmaSearchParam.get("dept") == "ALL" && !ecsLib.validateInput(grpInqire, scwin.initData.valInfo, false, false)) {
			comLib.alert($p, "전체 부서 조회시 성명 입력은 필수 입니다.");
			return;
		}
		var dept = dmaSearchParam.get("dept");
		var korname = dmaSearchParam.get("korname");

		var queryString = "";
		queryString = `?ecsChrgDeptId=${dept}`;
		queryString += `&usrNm=${korname}`;

		var option = {
			action : "zz/cmmn/retrieve-hrm-user.do"
			+ queryString,
			method : "get",
			resData : dltUserList,
			success : "scwin.inqireCallback",
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	/**
	 * 조회 CallBack 실행한다.
	 * @param <Object> resBody
	 * @return
	 */
	scwin.inqireCallback = function(resBody) {
		spnTotalRow.setValue(dltUserList.getRowCount());
	};

	/**
	 * 셀을 선택 후 선택 버튼 클릭시 해당 내용을 상세내역으로 표출한다.
	 * @param
	 * @return
	 */
	scwin.btnEdit_onclick = function() {
		var rowIndex = grdUserList.getFocusedRowIndex();
		if (rowIndex >= 0) {
			var rowData = dltUserList.getRowJSON(rowIndex);

			// 전달받은 부모창 <INPUT> ID에 EMPNO, NM SET
			var dataMap = $p.getComponentById(scwin.param.dataMap);
			dataMap.set(scwin.param.dataKey["empNo"], rowData.empno);
			dataMap.set(scwin.param.dataKey["empNm"], rowData.korname);
			//dataMap.set("planChargerEmpno", rowData.empno);
			//dataMap.set("planChargerNm", rowData.korname);

			// 모달 창 닫기
			$p.closePopup();
		}
	};

	scwin.grdUserList_oncelldblclick = function(row,col,colId) {
		scwin.btnEdit_onclick();
	};
	]]></script>
	</head>
	<body ev:onpageunload="scwin.onpageunload">
		<!-- <w2:wframe id="wfm_title" class="wfm_title" src="/ui/common/navigator.xml"></w2:wframe> -->
		<!--< w2:pageInherit id="comPage" src="/ui/common/content_common.xml"></w2:pageInherit> -->
		<w2:wframe id="wframeLeft" src="/ui/common/content_board.xml"></w2:wframe>
		<xf:group class="wrap">
			<xf:group class="search-box">
				<xf:group id="grpInqire" class="list">
					<xf:group class="w2tb" tagname="table">
						<w2:attributes>
							<w2:summary></w2:summary>
						</w2:attributes>
						<xf:group tagname="caption"></xf:group>
						<xf:group tagname="colgroup">
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
							<xf:group tagname="col"></xf:group>
						</xf:group>
						<xf:group tagname="tr">
							<xf:group class="w2tb_th cw1_9" tagname="th">
								<w2:attributes>
									<w2:scope>row</w2:scope>
								</w2:attributes>
								<w2:span label="부서"></w2:span>
							</xf:group>
							<xf:group class="w2tb_td cw4_5" tagname="td">
								<w2:autoComplete displayMode="label" editType="select" search="contain" submenuSize="auto" useKeywordHighlight="true"
									visibleRowNum="15" chooseOptionLabel="- 전체 -" chooseOption="true" chooseOptionValue="ALL" ref="data:dmaSearchParam.dept">
									<w2:choices>
										<w2:itemset nodeset="data:dltAutoCondition1">
											<w2:label ref="cmmnCdNm"></w2:label>
											<w2:value ref="cmmnCd"></w2:value>
										</w2:itemset>
									</w2:choices>
								</w2:autoComplete>
							</xf:group>
							<xf:group class="w2tb_th cw1_9" tagname="th">
								<w2:attributes>
									<w2:scope>row</w2:scope>
								</w2:attributes>
								<w2:span label="성명"></w2:span>
							</xf:group>
							<xf:group class="w2tb_td cw3" tagname="td">
								<xf:input id="ibxKorname" ref="data:dmaSearchParam.korname" ev:onkeydown="ecsLib.ibxEnterEvent"></xf:input>
							</xf:group>
						</xf:group>
					</xf:group>
				</xf:group>
				<xf:group class="btn-group">
					<!-- userData1="Q" 조회버튼 추후 추가 -->
					<w2:anchor id="btnInqire" class="fa fa-search btn_sh" outerDiv="false" ev:onclick="scwin.btnInqire_onclick">
						<xf:label><![CDATA[조회]]></xf:label>
					</w2:anchor>
				</xf:group>
			</xf:group>
			<xf:group class="popup-content-area">
				<xf:group class="con-box">
					<xf:group class="title-group">
						<xf:group tagname="h3">
							<w2:span label="직원명단"></w2:span>
							<w2:span id="spnTotalRow" class="title-num" displayFormat="###,###,###" label="0"></w2:span>
						</xf:group>
					</xf:group>
					<xf:group class="list-box box">
						<w2:gridView id="grdUserList" class="resized" dataList="dltUserList" readOnly="true" checkReadOnlyOnPaste="true"
							checkReadOnlyOnCut="true" focusMode="row" useShiftKey="true" sortable="true" tooltipDisplay="true" defaultCellHeight="35"
							visibleRowNum="10" rowNumVisible="true" rowNumHeaderValue="No" rowNumWidth="80" style="min-height:24rem;" ev:oncelldblclick="scwin.grdUserList_oncelldblclick">
							<w2:header>
								<w2:row>
									<w2:column id="hDept" inputType="text" value="부서" width="220"></w2:column>
									<w2:column id="hPosit" inputType="text" value="지위" width="180"></w2:column>
									<w2:column id="hGrade" inputType="text" value="직급" width="180"></w2:column>
									<w2:column id="hKorname" inputType="text" value="성명" width="180"></w2:column>
									<w2:column id="hEmpno" inputType="text" value="사원번호" width="180" hidden="true"></w2:column>
								</w2:row>
							</w2:header>
							<w2:gBody>
								<w2:row>
									<w2:column id="dept" inputType="text"></w2:column>
									<w2:column id="posit" inputType="text"></w2:column>
									<w2:column id="grade" inputType="text"></w2:column>
									<w2:column id="korname" inputType="text"></w2:column>
									<w2:column id="empno" inputType="text" hidden="true"></w2:column>
								</w2:row>
							</w2:gBody>
						</w2:gridView>
					</xf:group>
				</xf:group>
			</xf:group>
			<xf:group class="footer">
				<xf:group class="btn-group">
					<!-- userData1="S" 선택버튼 추후 추가 -->
					<w2:anchor id="btnEdit" ev:onclick="scwin.btnEdit_onclick" outerDiv="false">
						<xf:label><![CDATA[선택]]></xf:label>
					</w2:anchor>
				</xf:group>
			</xf:group>
		</xf:group>
	</body>
</html>