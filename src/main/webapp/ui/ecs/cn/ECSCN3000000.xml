		<script lazy="false" type="text/javascript"><![CDATA[
	/**
	 * 화면 초기화에 필요한 로직을 수행한다.
	 * @param
	 * @return
	 */
	scwin.initScreen = function() {
		// 화면초기화 공통 함수 호출
		comLib.initForm($p, "ECSCN3000000", {"initScreenCallback" : scwin.searchDatas});
		// ecsLib.setChartResizeObserver(this);
	};

	/**
	 * 화면 초기 데이터들을 조회한다.
	 * @param
	 * @return
	 */
	scwin.searchDatas = function() {
		// 조회조건 설정
		scwin.initSearchParam();
		// 화면 데이터 조회
		//scwin.btnInqire_onclick();
	};

	/**
	 * 조회조건 초기화에 필요한 로직을 수행한다.
	 * @param
	 * @return
	 */
	scwin.initSearchParam = function() {
		var endDt = utilLib.getCurrentDate("yyyyMMdd");
		var strtDt = utilLib.addDay(endDt, -7);
		var basinCd = "ALL";

		var params = $p.getParameter("param");
		if (params) {
			if (params.year) {
				strtDt = String(params.year) + endDt.substr(4, 2) + "31";
				endDt = String(params.year) + endDt.substr(4, 2) + "01";
			}
			if (params.basinCd) {
				basinCd = params.basinCd;
				acbBasin.setValue(basinCd);
			}
		}

		dmaSearchParam.set("strtDt" , strtDt);
		dmaSearchParam.set("endDt" , endDt);
		dmaSearchParam.set("basinCd", basinCd);
		dmaSearchParam.set("deptCd", "ALL");
		dmaSearchParam.set("bplcCd", "ALL");
	};

	/**
	 * 조회조건에 맞게 data를 조회한다.
	 * @param
	 * @return
	 */
	scwin.btnInqire_onclick = function() {
		var strtDate = dmaSearchParam.get("strtDt");
		var endDate = dmaSearchParam.get("endDt");
		var ecsBasinDivCd = dmaSearchParam.get("basinCd");
		var ecsChrgDeptId = dmaSearchParam.get("deptCd");
		var ecsCnstscDivCd = dmaSearchParam.get("bplcCd");

		if (String(strtDate).length != 8 || String(endDate).length != 8) {
			// 조회기간이 올바르지 않습니다.
			alert(utilLib.getMessage("ECS.INFO.00011")[0]);
			return;
		} else if (utilLib.minusMonths(strtDate, endDate) > 3 ? true : false) {
			// 조회기간은 {0}을 넘어갈 수 없습니다. 다시 설정해 주세요.
			alert(utilLib.getMessage("ECS.INFO.00012", "3개월")[0]);
			return;
		} else if (parseInt(strtDate) > parseInt(endDate)) {
			// 시작년월이 종료년월일보다 클수 없습니다.
			alert(utilLib.getMessage("ECS.INFO.00014")[0]);
			return;
		}
		/*
		else if (ecsChrgDeptId == "ALL" && ecsCnstscDivCd == "ALL") {
			// 부서나 사업장을 선택해주세요.
			alert("부서나 사업장을 선택해주세요.");
			return;
		}
		*/

		var queryString = `?strtDt=${strtDate}`;
		queryString += `&endDt=${endDate}`;
		queryString += `&ecsBasinDivCd=${ecsBasinDivCd}`;
		queryString += `&ecsChrgDeptId=${ecsChrgDeptId}`;
		queryString += `&ecsCnstscDivCd=${ecsCnstscDivCd}`;

		var option = {
			action : "cn/cnsmppttrn/retrieve-cnsmp-pttrn.do"
				+ queryString,
			method : "get",
			resData : dltCnsmpPttrnList,
			success : "scwin.inqireCallback",
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	/**
	 * 조회 CallBack 실행한다.
	 * @param
	 * @return
	 */
	scwin.inqireCallback = function() {
		spnTotalRow.setValue(dltCnsmpPttrnList.getRowCount());

		grdCnsmpPttrnList.setDisplayFormat("ymd", "####-##-##");
		grdCnsmpPttrnList.setHeaderValue("hYmd", "년월일");
		grdCnsmpPttrnList.setHeaderValue("hCnstqyAcmtl", "소비량 일누계(kWh/일)");
		grdCnsmpPttrnList.setHeaderValue("hUswtrSqtyAcmtl", "용수공급량 일누계(㎥/일)");
		grdCnsmpPttrnList.setHeaderValue("hEpbuAcmtl", "일별 전력원단위(kWh/㎥)");
	};

	/**
	 * 조회박스 선택별 값을 세팅한다.
	 * @param info
	 * @return
	 */
	scwin.acbBasin_onviewchange = function(info) {
		var ecsBasinDivCd = info.newValue;
		dmaSearchParam.set("basinCd", ecsBasinDivCd);

		var queryString = `?ecsBasinDivCd=${ecsBasinDivCd}`;
		var option = {
			action : "zz/cmmn/retrieve-cnsmp-sttus-cnd-kepco-dept.do"
				+ queryString,
			method : "get",
			resData : dltAutoCondition2,
			success : "",
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
		dmaSearchParam.set("deptCd", "ALL");
		scwin.acbDept_onviewchange({ "newValue" : "ALL" });
	};

	scwin.acbDept_onviewchange = function(info) {
		var ecsChrgDeptId = info.newValue;
		dmaSearchParam.set("deptCd", ecsChrgDeptId);
		var ecsBasinDivCd = dmaSearchParam.get("basinCd");

		var queryString = `?ecsBasinDivCd=${ecsBasinDivCd}`;
		queryString += `&ecsChrgDeptId=${ecsChrgDeptId}`;
		var option = {
			action : "zz/cmmn/retrieve-bplc.do"
				+ queryString,
			method : "get",
			resData : dltAutoCondition3,
			success : "",
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
		dmaSearchParam.set("bplcCd", "ALL");
	};

	scwin.acbBplc_onviewchange = function(info) {
		dmaSearchParam.set("bplcCd", info.newValue);
	};

	/**
	 * 차트보기 버튼 클릭시 팝업창을 연다.
	 * @param
	 * @return
	 */
	scwin.btnChart_onclick = function() {
		var url = "/ui/ecs/cn/ECSCN3100000.xml";

		var options = {
			id : "ECSCN3100000",
			title : "부서별 소비실적 차트",
			popupName : "부서별 소비실적 차트",
			width : 1400,
			height : 686,
			top : -1,
			left : 0,
			modal : true,
			closeAction : "",
			// popupParam : ""
		};
		comLib.openPopup($p, "ECSCN3100000", url, options);
	};

	/**
	 * 그리드 소수점 첫째자리까지 표시 한다.
	 * @param value
	 * @return
	 */
	scwin.dsplZeroFrmt = function(value) {
		return ecsLib.dsplZeroFrmt(value, 1);
	};

	/**
	 * 그리드 소수점 넷째자리까지 표시 한다.
	 * @param value
	 * @return
	 */
	scwin.dsplZeroFrmt2 = function(value) {
		return ecsLib.dsplZeroFrmt(value, 4);
	};

	/**
	 * 그리드 합계 소수점 첫째자리까지 표시 한다.
	 * @param value
	 * @return
	 */
	scwin.dsplFrmt = function(value) {
		return ecsLib.dsplFrmt(value, 1);
	};

	//============================================================================================
	// 엑셀
	//============================================================================================
	/**
	 * 그리드의 내용을 엑셀로 다운로드 한다.
	 * @return
	 */
	scwin.btnDownExcel_onclick = function() {
		var menuNm = $p.getComponentById("wfm_title").scope.$p.getComponentById("tbxScreenTitle").getValue();
		var subTitleNm = spnSubTitle.getValue();
		// 엑셀 내부 타이틀 추가_240105
		var infoArr = [];
		var infoObj = {
			rowIndex 	: 0,
			colIndex 	: 0,
			rowSpan 	: 0,
			colSpan 	: 10,
			text 		: `${menuNm}_` + `${subTitleNm}`,
			textAlign 	: "left"
		};
		infoArr.push(infoObj);

		comLib.downloadExcel(grdCnsmpPttrnList, {
			fileName : `${menuNm}_` + `${subTitleNm}.xlsx`,
			autoSizeColumn : true,
			useDataFormat: true,
			applyDataFormat : true,
			decimal : "auto"
		}, infoArr);
	};
]]></script>
	</head>
