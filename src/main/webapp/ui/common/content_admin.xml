		<script type="javascript" lazy="false"><![CDATA[ 
	/**
	 * 화면 초기화에 필요한 로직을 수행한다.
	 */
	scwin.initScreen = function() {
		$(".nav-title-group .close").click(function() {
			$(".nav-board").removeClass("board-on");
			comLib.removeSrc();
		});
	};

	scwin.selectAdmin = function(usrId) {
		$(".adminLi").removeClass("active");
		eval("liId_" + usrId).classList.add("active");
		$("table.creat").addClass("table-on");
		var dltSysAthrJson = dltSysAthr.getMatchedJSON("usrId", usrId, true, 0, dltSysAthr.getRowCount());
		utilLib.clearDcObj(dmaSysAthr);
		dmaSysAthr.set("adminDivCd", dltSysAthrJson[0].adminDivCd);
		dmaSysAthr.set("adminDivNm", dltSysAthrJson[0].adminDivNm);
		dmaSysAthr.set("sysDivCd", dltSysAthrJson[0].sysDivCd);
		dmaSysAthr.set("usrId", dltSysAthrJson[0].usrId);
		dmaSysAthr.set("dtyNm", dltSysAthrJson[0].dtyNm);
		dmaSysAthr.set("conectIp", dltSysAthrJson[0].conectIp);
		dmaSysAthr.set("useYn", dltSysAthrJson[0].useYn);
		dmaSysAthr.set("korname", dltSysAthrJson[0].korname);
		dmaSysAthr.set("dept", dltSysAthrJson[0].dept);
		dmaSysAthr.set("posit", dltSysAthrJson[0].posit);
		dmaSysAthr.set("dphno", dltSysAthrJson[0].dphno);
		adminUsr.setValue(dmaSysAthr.get("korname")+" "+dmaSysAthr.get("posit")+" "+dltSysAthrJson[0].dphno);
		dtyInfo.setValue(dmaSysAthr.get("dtyNm"));
	};

	/**
	 * 확인버튼클릭
	 * @param 저장할 데이터
	 * @return 
	 */
	scwin.btnAdminMail_onclick = function() {
		// 입력값 셋팅
		if (dmaSysAthr.get("subject") == "") {
			comLib.alert($p, utilLib.getMessage("SCM.INFO.00004", "메일 제목"));
			return false;
		}
		if (dmaSysAthr.get("content") == "") {
			comLib.alert($p, utilLib.getMessage("SCM.INFO.00004", "메일 내용"));
			return false;
		}
		if (dmaSysAthr.get("subject") != "" && dmaSysAthr.get("content") != "") {
			comLib.confirm($p, utilLib.getMessage("SCM.INFO.00335"), "mailConfirmCallback");
		}
	};

	/**
	 * 저장처리.
	 */
	scwin.mailConfirmCallback = function() {
		var requestData = {};
		requestData.data = dmaSysAthr.getJSON();
		//requestData.data1 = _dltNttFile.getModifiedJSON();

		var option = {
			action : "sc/admin/adminMailSend.do",
			reqData : requestData,
			success : "scwin.mailCallback",
			//success : "scwin.saveCallback",
			//savedToken : true,
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	scwin.mailCallback = function(resBody) {
		if (resBody.message.code == 'success') {
			dmaSysAthr.set("subject", "");
			dmaSysAthr.set("content", "");
			comLib.alert($p, resBody.message.code_name);
		}
		else{
			alert("fail");
		}
	};

	$p.$(".nav-title-group .close").click(function() {
		$(".nav-board").removeClass("board-on");
		comLib.removeSrc($p);
	});
		]]></script>
