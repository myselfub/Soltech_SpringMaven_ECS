        if (firstChild.getAttribute(item)) {
            usrDfnVu2[item] = firstChild.getAttribute(item);
        }
    });
    usrDfnVu2 = JSON.stringify(usrDfnVu2);
    
    var textEmt = emt.querySelector("tspan");
    var cmmnCdNm = textEmt.textContent;
    cmmnCdDc += `-${cmmnCdNm}`;
    
    var usrDfnVu3 = {
