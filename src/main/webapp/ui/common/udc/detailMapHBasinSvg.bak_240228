    var query = `INSERT INTO ECS.TC_ECS_CD (CLS_CD, CMMN_CD, CMMN_CD_NM, CMMN_CD_DC, UPPER_CLS_CD, UPPER_CMMN_CD, USE_YN, SORT_ORDR, SAP_LNK_YN, USR_DFN_VU1, USR_DFN_VU2, USR_DFN_VU3, USR_DFN_VU4, USR_DFN_VU5, USR_DFN_VU6, USR_DFN_VU7, USR_DFN_VU8, FRST_REGIST_DT, FRST_RGSTR_ID, LAST_UPDT_DT, LAST_UPDUSR_ID) VALUES('${clsCd}', '${cmmnCd}', '${cmmnCdNm}', '${cmmnCdDc}', '${upperClsCd}', '${upperCmmnCd}', '${useYn}', ${sortOrdr}, '${sapLnkYn}', '${usrDfnVu1}', '${usrDfnVu2}', '${usrDfnVu3}', NULL, NULL, NULL, NULL, NULL, TIMESTAMP '2023-01-01 00:00:00.000000', 'Soltech', TIMESTAMP '2023-01-01 00:00:00.000000', 'Soltech');`
    querys.push(query);
});

