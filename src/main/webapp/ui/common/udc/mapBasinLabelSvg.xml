		<xf:group class="map-basin-label" tagname="svg" pluginName="map_basin_label">
			<script ev:event="oncreated(options)" type="text/javascript"><![CDATA[
				/**
				 * //property handling
				 * $w.log("id:" + options.id);
				 * $w.log("style:" + options.style);
				 * $w.log("class:" + options.class);
				 * $w.log("ref:" + options.ref);
				 *
				 * //event trigger
				*/
				// 초기 수행함수
				this.initMapBasinLabel = function() {
					// fill 설정
					if (options.fill && options.fill != "") {
						var color = options.fill;
						var inColor = "";
						var outColor = "";
						if (color == "H") {
							inColor = "#F2FFDF";
							outColor = "url(#" + grpLinearH.getID() + ")";
						} else if (color == "G") {
							inColor = "#FFFADF";
							outColor = "url(#" + grpLinearG.getID() + ")";
						} else if (color == "N") {
							inColor = "#DBE9FF";
							outColor = "url(#" + grpLinearN.getID() + ")";
						} else if (color == "Y") {
							inColor = "#FFE3F4";
							outColor = "url(#" + grpLinearY.getID() + ")";
						}
						if (inColor != "") {
							document.getElementById(grpMapInLabelFill.getID()).setAttribute("fill", inColor);
						} else {
							document.getElementById(grpMapInLabelFill.getID()).setAttribute("fill", color);
						}

						if (outColor != "") {
							document.getElementById(grpMapOutLabelFill.getID()).setAttribute("fill", outColor);
						} else {
							document.getElementById(grpMapOutLabelFill.getID()).setAttribute("fill", color);
						}
					}
					if (options.width && options.width != "") {
						document.getElementById(this.getID()).setAttribute("width", options.width);
					}
				};

				// 초기 실행함수 수행
				this.initMapBasinLabel();
				]]></script>
