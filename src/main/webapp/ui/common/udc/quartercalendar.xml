								<xf:group tagname="tr">
									<xf:group tagname="td" style="" id="btn_Quarter01" class="w2tb_td">
										<xf:group tagname="a" style="" id="" class="">
											<script ev:event="onclick" type="javascript"><![CDATA[
												udc_obj.clickQuarters("01");
											]]></script>
											<w2:attributes>
