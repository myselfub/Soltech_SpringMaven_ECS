												udc_obj.clickEndYears("09");
					 						]]></script>
											<w2:attributes>
												<w2:href>#none</w2:href>
											</w2:attributes>
											<w2:span style="" id="span_EndYear09" label="11"></w2:span>
										</xf:group>
									</xf:group>
									<xf:group tagname="td" style="" id="btn_EndYear10" class="w2tb_td">
										<xf:group tagname="a" style="" id="" class="">
											<script ev:event="onclick" type="javascript"><![CDATA[
												udc_obj.clickEndYears("10");
					 						]]></script>
											<w2:attributes>
												<w2:href>#none</w2:href>
											</w2:attributes>
											<w2:span style="" id="span_EndYear10" label="12"></w2:span>
										</xf:group>
									</xf:group>
								</xf:group>
							</xf:group>
						</xf:group>
					</xf:group>
				</xf:group>
				<xf:group style="" id="" class="gb_btnarea">
					<w2:anchor outerDiv="false" style="" id="" class="btn_cancle">
						<script ev:event="onclick" type="javascript"><![CDATA[
							div_PeriodYear.setStyle("display", "none");
	 					]]></script>
						<xf:label><![CDATA[취소]]></xf:label>
					</w2:anchor>
					<w2:anchor outerDiv="false" style="" id="" class="btn_ok">
						<script ev:event="onclick" type="javascript"><![CDATA[
							udc_obj.changePeriodYear();
	 					]]></script>
						<xf:label><![CDATA[확인]]></xf:label>
					</w2:anchor>
				</xf:group>
			</xf:group>
			<w2:style type="text/css"><![CDATA[ ]]></w2:style>
			<script ev:event="oncreated(options)" type="text/javascript"><![CDATA[
				/**
				* //property handling
				* $w.log("id:" + options.id);
				* $w.log("strtMonth:" + options.strtDate);
				* $w.log("endMonth:" + options.endDate);
				* $w.log("strtDateRef:" + options.strtDateRef);
				* $w.log("endDateRef:" + options.endDateRef);
				*
				* //event trigger
				* udc_obj.trigger("onBtnCalendarClick"); 
				*/
			//초기 수행함수 
			this.initPeriodYearCalendar = function() {
				tbx_StrtYear.hide();
				tbx_EndYear.hide();
				this.today = "";
				this.selectedStrtDate = "";
				this.selectedEndDate = "";

				var tmpDate = new Date();
				var year = tmpDate.getFullYear();
				year = year + "";
				year = year.substr(0, 3) + "0";

				var startYear = parseInt(year);
				var endYear = parseInt(year) + 9;

				tbx_StrtYear.setValue(startYear);
				tbx_StrtYear_Label.setValue(startYear + "~" + endYear);
				tbx_EndYear.setValue(startYear);
				tbx_EndYear_Label.setValue(startYear + "~" + endYear);

				// ref 설정
				if (options.strtDateRef != undefined) {
					ibx_StrtDate.setRef(options.strtDateRef);
				}
				if (options.endDateRef != undefined) {
					ibx_EndDate.setRef(options.endDateRef);
				}

				// udc의 초기 설정값
				if (ibx_StrtDate.getValue() == "" && options.strtDate != undefined) {
					ibx_StrtDate.setValue(options.strtDate);
				}
				
				if (ibx_EndDate.getValue() == "" && options.endDate != undefined) {
					ibx_EndDate.setValue(options.endDate);
				}

				this.changeStrtYear(startYear);
				this.changeEndYear(startYear);
			};

			this.showPeriodYearCalendar = function() {
				this.selectedStrtDate = ibx_StrtDate.getValue();
				this.selectedEndDate = ibx_EndDate.getValue();

				if(div_PeriodYear.getStyle("display") == "none") {
					div_PeriodYear.setStyle("display", "");
				} else {
					div_PeriodYear.setStyle("display", "none");
				}
			};
		
			// 시작 년도가 변경된 경우
			this.changeStrtYear = function(strtDate) {
				tbx_StrtYear.setValue(strtDate);

				var startYear = parseInt(strtDate);
				var endYear = parseInt(strtDate) + 9;

				tbx_StrtYear.setValue(startYear);
				tbx_StrtYear_Label.setValue(startYear + "~" + endYear);

				span_StrYear99.setValue(startYear - 1);
				for (var i = 0; i <= 10; i++) {
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);
					eval("span_StrYear" + month).setValue(startYear);
					eval("btn_StrYear" + month).removeClass("selected");
					if (eval("span_StrYear" + month).getLabel() == this.selectedStrtDate) {
						eval("btn_StrYear" + month).addClass("selected");
					}
					startYear++;
				}
			};

			// 시작월 클릭시
			this.clickStrtYears = function(strtYear) {
				eval("btn_StrYear99").removeClass("selected");
				for (var i = 0; i <= 10; i++) {
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);
					eval("btn_StrYear" + month).removeClass("selected");
				}
				eval("btn_StrYear" + strtYear).addClass("selected");

				// this.selectedStrtDate = tbx_StrtYear.getValue() + "-" + strtMonth;
				this.selectedStrtDate = eval("span_StrYear" + strtYear).getLabel();
			}

			// 년도클릭시
			this.onStrtYears = function(strtYear) {
				for (var i = 0; i <= 10; i++) {
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);
					eval("btn_StrYear" + month).removeClass("selected");

					if (eval("span_StrYear" + month).getLabel() == strtYear) {
						eval("btn_StrYear" + month).addClass("selected");
					}
				}
				this.selectedDate = strtYear;
			};

			// 시작 년도가 변경된 경우
			this.changeEndYear = function(endDate) {
				tbx_EndYear.setValue(endDate);

				var startYear = parseInt(endDate);
				var endYear = parseInt(endDate) + 9;

				tbx_EndYear.setValue(startYear);
				tbx_EndYear_Label.setValue(startYear + "~" + endYear);

				span_EndYear99.setValue(startYear - 1);
				for (var i = 0; i <= 10; i++) {
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);
					eval("span_EndYear" + month).setValue( startYear);
					eval("btn_EndYear" + month).removeClass("selected");
					if (eval("span_EndYear" + month).getLabel() == this.selectedEndDate) {
						eval("btn_EndYear" + month).addClass("selected");
					}
					startYear ++;
				}
			};

			// 종료월 클릭시 
			this.clickEndYears = function(endYear) {
				eval("btn_EndYear99").removeClass("selected");
				for (var i = 0; i <= 10; i++) {
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);
					eval("btn_EndYear" + month).removeClass("selected");
				}
				eval("btn_EndYear" + endYear).addClass("selected");

				// this.selectedEndDate = tbx_EndYear.getValue() + "-" + endMonth;
				this.selectedEndDate = eval("span_EndYear" + endYear).getLabel();
			};

			// 년도클릭시
			this.onEndYears = function(endYear) {
				for (var i = 0; i <= 10; i++) {
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);
					eval("btn_EndYear" + month).removeClass("selected");

					if (eval("span_EndYear" + month).getLabel() == endYear ) {
						eval("btn_EndYear" + month).addClass("selected");
					}
				}
				this.selectedDate = endYear;
			};

			// 확인 버튼 클릭시 
			this.changePeriodYear = function() {
				if (parseInt(this.selectedStrtDate) > parseInt(this.selectedEndDate)) {
					alert("시작년이 종료년보다 클수 없습니다.");
					return false;
				}

				ibx_StrtDate.setValue(this.selectedStrtDate + "");
				ibx_EndDate.setValue(this.selectedEndDate + "");

				div_PeriodYear.setStyle("display", "none");
			}

			udc_obj.getStrtDate = function() {
				if (ibx_StrtDate.getValue == "") {
					return null;
				} else {
					return ibx_StrtDate.getValue();
				}
			};

			udc_obj.getEndDate = function() {
				if(ibx_EndDate.getValue == "") {
					return null;
				} else {
					return ibx_EndDate.getValue();
				}
			};

			udc_obj.setStrtDate = function(strtDate) {
				ibx_StrtDate.setValue(strtDate);
			};

			udc_obj.setEndDate = function(endDate) {
				ibx_EndDate.setValue(endDate);
			};

			udc_obj.focusStrtDate = function(endDate) {
				ibx_StrtDate.focus();
			};

			udc_obj.focusEndDate = function(endDate) {
				ibx_EndDate.focus();
			};

			// 초기 실행함수 수행
			this.initPeriodYearCalendar();
			]]></script>
			<w2:style type="text/css"><![CDATA[ ]]></w2:style>
		</xf:group>
	</body>
</html>