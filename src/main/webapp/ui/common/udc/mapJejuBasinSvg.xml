		<xf:group class="map-basin-jeju" tagname="svg" pluginName="map_jeju_basin">
			<script ev:event="oncreated(options)" type="text/javascript"><![CDATA[
				/**
				 * //property handling
				 * $w.log("id:" + options.id);
				 * $w.log("style:" + options.style);
				 * $w.log("class:" + options.class);
				 * $w.log("ref:" + options.ref);
				 *
				 * //event trigger
				*/
				// 초기 수행함수 
				this.initJejuBasin = function() {
					// fill 설정
					var selector = "#" + this.getID() + " .map-basin";
					if (options.fill && options.fill != "") {
						document.querySelectorAll(selector).forEach(elm => elm.setAttribute("fill", options.fill));
					} else {
						document.querySelectorAll(selector).forEach(elm => elm.classList.add("map-basin-jeju-fill"));
					}
				};

				// 초기 실행함수 수행
				this.initJejuBasin();
				]]></script>
