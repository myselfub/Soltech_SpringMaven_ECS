			<script ev:event="oncreated(options)" type="text/javascript"><![CDATA[
				/**
				 * //property handling
				 * $w.log("id:" + options.id);
				 * $w.log("style:" + options.style);
				 * $w.log("class:" + options.class);
				 * $w.log("ref:" + options.ref);
				 *
				 * //event trigger
				*/
				// 초기 수행함수 
				this.initWaterDropShape = function() {
					// fill 설정
					var fill = "";
					if (options.fill && options.fill != "") {
						fill = options.fill;
					} else {
						fill = "url(#" + grpBeltMenuLinear.getID() + ")";
					}
					document.getElementById(grpBeltMenuFill.getID()).setAttribute("fill", fill);

					// filter 설정
					var filter = "";
					if (options.filter && options.filter != "") {
						filter = options.filter;
					} else {
						filter = "url(#" + grpBeltMenuShadow.getID() + ")";
					}
					document.getElementById(grpBeltMenuFilter.getID()).setAttribute("filter", filter);

					document.getElementById(grpBeltMenuBackFill.getID()).setAttribute("fill", "url(#" + grpBeltMenuBackLinear.getID() + ")");
					document.getElementById(grpBeltMenuBackFill.getID()).setAttribute("mask", "url(#" + grpBeltMenuMask.getID() + ")");
				};

				// 초기 실행함수 수행
				this.initWaterDropShape();
				]]></script>
