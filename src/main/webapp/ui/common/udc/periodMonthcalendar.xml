			<script ev:event="oncreated(options)" type="text/javascript"><![CDATA[
				/**
				* //property handling
				* $w.log("id:" + options.id);
				* $w.log("strtMonth:" + options.strtDate);
				* $w.log("endMonth:" + options.endDate);
				* $w.log("strtDateRef:" + options.strtDateRef);
				* $w.log("endDateRef:" + options.endDateRef);
				*
				* //event trigger
				* udc_obj.trigger("onBtnCalendarClick"); 
				*/

			// 초기 수행함수 
			this.initPeriodMonthCalendar = function() {
				this.today = "";
				this.selectedStrtDate = "";
				this.selectedEndDate = "";

				var tmpDate = new Date();
				var year = tmpDate.getFullYear();
				var month = tmpDate.getMonth() + 1;

				if (parseInt(month) < 10) {
					month = "0" + month;
				}
				this.today = year + month+"";

				tbx_StrtYear.setValue( year );
				tbx_EndYear.setValue( year );

				// udc의 초기 설정값
				if (ibx_StrtDate.getValue() == "" && options.strtDate != undefined) {
					ibx_StrtDate.setValue(options.strtDate);
				}
				if (ibx_EndDate.getValue() == "" && options.endDate != undefined) {
					ibx_EndDate.setValue(options.endDate);
				}

				//ref 설젇 
				if(options.strtDateRef != undefined) {
					ibx_StrtDate.setRef(options.strtDateRef);
				}
				if(options.endDateRef != undefined) {
					ibx_EndDate.setRef(options.endDateRef);
				}
			};

			this.showPeriodMonthCalendar = function() {
				this.selectedStrtDate = ibx_StrtDate.getValue();
				this.selectedEndDate = ibx_EndDate.getValue();

				if (this.selectedStrtDate.length >= 4) {
					this.changeStrtYear(this.selectedStrtDate);
				}
				
				if (this.selectedEndDate.length >= 4) {
					this.changeEndYear(this.selectedEndDate);
				}

				if (div_PeriodMonth.getStyle( "display") == "none") {
					div_PeriodMonth.setStyle( "display", "");
				} else {
					div_PeriodMonth.setStyle( "display", "none");
				}
			};

			//시작 년도가 변경된 경우
			this.changeStrtYear = function(strtDate) {
				tbx_StrtYear.setValue(strtDate.substr(0, 4));
				for (var i = 1; i <= 12; i++) {
					// 월 구성 '##'
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);

					eval("btn_StrtMonth" + month).removeClass("today");

					// 변경된 년도가 올해인 경우 현재 월에 today 클래스를 추가하여 화면에 표시되도록 함 
					if (strtDate.substr(0, 4) == this.today.substr(0, 4)) {
						if(month == this.today.substr(4, 2)) {
							eval("btn_StrtMonth" + month).addClass("today");
						}
					}
					// 선택된 월 표시
					eval("btn_StrtMonth" + month).removeClass("selected");
					if (strtDate.substr(0, 4) == this.selectedStrtDate.substr(0, 4)) {
						if(month == this.selectedStrtDate.substr(4, 2)) {
							eval("btn_StrtMonth" + month).addClass("selected");
						}
					}
				}
				// this.selectedStrtDate = strtDate.substr(0,4);
			};

			// 시작월 클릭시
			this.clickStrtMonths = function(strtMonth) {
				for(var i = 1; i <= 12; i++) {
					// 월 구성 '##'
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);
					eval("btn_StrtMonth" + month).removeClass("selected");

					if(month == strtMonth) {
						eval("btn_StrtMonth" + month).addClass("selected");
					}
				}

				// this.selectedStrtDate = tbx_StrtYear.getValue() + "-" + strtMonth;
				this.selectedStrtDate = tbx_StrtYear.getValue() + strtMonth;
			};

			//시작 년도가 변경된 경우
			this.changeEndYear = function(endDate) {
				tbx_EndYear.setValue(endDate.substr(0, 4));
				for(var i = 1; i <= 12; i++) {
					// 월 구성 '##'
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);

					eval("btn_EndMonth" + month).removeClass("today");

					// 변경된 년도가 올해인 경우 현재 월에 today 클래스를 추가하여 화면에 표시되도록 함 
					if (endDate.substr(0, 4) == this.today.substr(0, 4)) {
						if(month == this.today.substr(4, 2)) {
							eval("btn_EndMonth" + month).addClass("today");
						}
					}
					// 선택된 월 표시
					eval("btn_EndMonth" + month).removeClass("selected");
					if(endDate.substr(0,4) == this.selectedEndDate.substr(0, 4)) {
						if(month == this.selectedEndDate.substr(4, 2)) {
							eval("btn_EndMonth" + month).addClass("selected");
						}
					}
				}
				// this.selectedStrtDate = strtDate.substr(0,4);
			};

			//종료월 클릭시 
			this.clickEndMonths = function(endMonth) {
				for (var i = 1; i <= 12; i++) {
					// 월 구성 '##'
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);
					eval("btn_EndMonth" + month).removeClass("selected");

					if(month == endMonth) {
						eval("btn_EndMonth" + month).addClass("selected");
					}
				}

				// this.selectedEndDate = tbx_EndYear.getValue() + "-" + endMonth;
				this.selectedEndDate = tbx_EndYear.getValue() + endMonth;
			};

			// 확인 버튼 클릭시 
			this.changePeriodMonth = function() {
				// if (this.selectedStrtDate.length == 7 && this.selectedEndDate.length == 7) {
				if (this.selectedStrtDate.length == 6 && this.selectedEndDate.length == 6) {
					if (parseInt(this.selectedStrtDate) > parseInt(this.selectedEndDate)) {
						alert("시작년월이 종료년월보다 클수 없습니다.");
						return false;
					} 
				}

				// if (this.selectedStrtDate.length == 7) {
					// ibx_StrtDate.setValue(this.selectedStrtDate);
				// }
				// if (this.selectedEndDate.length == 7) {
					// ibx_EndDate.setValue(this.selectedEndDate);
				// }
				if (this.selectedStrtDate.length == 6) {
					ibx_StrtDate.setValue(this.selectedStrtDate);
				}
				if (this.selectedEndDate.length == 6) {
					ibx_EndDate.setValue(this.selectedEndDate);
				}

				div_PeriodMonth.setStyle("display", "none");
			};

			/**
			* 년월 문자열 display
			* @param <String> value yyyyMM
			* @return yyyy-MM
			*/
			udc_obj.displayCalFromMonth = function(value) {
				var date_dlmt = "-";
				value = value.replaceAll("-", "");
				var year_data = "";
				var month_data = "";
				var i;
				var flagYn;
				if (value.length == 6) {
					for (i = 0; i < 6; i++) {
					var c = value.charAt(i);
					if ((c < '0' || c > '9')) {
							flagYn = false;
						} else {
							flagYn = true;
						}
						if (i < 4) {
							year_data += c;
						} else if (i >= 4 && i < 6) {
							month_data += c;
						}
					}
						if (flagYn) {
							var mnthst = month_data;
							var mnth = parseInt(mnthst, 10);
							if (mnth < 1 || mnth > 12) {
								ibx_StrtDate.setValue( "" );
								// return "";
							} else {
								ibx_StrtDate.setValue(value.substr(0, 4) + scwin.lpad(value.substr(4, 2), 2, "0"));
								// return value.substr(0, 4) + date_dlmt + scwin.lpad(value.substr(4, 2), 2, "0");
							}
						} else {
							ibx_StrtDate.setValue("");
							//return "";
						}
				}
				if (value.length < 6) {
					ibx_StrtDate.setValue( "" );
					// return "";
				}
			};

			/**
			* 년월 문자열 display
			* @param <String> value yyyyMM
			* @return yyyy-MM
			*/
			udc_obj.displayCalToMonth = function(value) {
				var date_dlmt = "-";
				value = value.replaceAll("-", "");
				var year_data = "";
				var month_data = "";
				var i;
				var flagYn;
				if (value.length == 6) {
					for (i = 0; i < 6; i++) {
					var c = value.charAt(i);
					if ((c < '0' || c > '9')) {
							flagYn = false;
						}else{
							flagYn = true;
						}
						if (i < 4) {
							year_data += c;
						} else if (i >= 4 && i < 6) {
							month_data += c;
						}
					}
					if (flagYn) {
						var mnthst = month_data;
						var mnth = parseInt(mnthst, 10);
						if (mnth < 1 || mnth > 12) {
							ibx_EndDate.setValue("");
							// return "";
						}else{
							ibx_EndDate.setValue(value.substr(0, 4) + scwin.lpad(value.substr(4, 2), 2, "0"));
							// return value.substr(0, 4) + date_dlmt + scwin.lpad(value.substr(4, 2), 2, "0");
						}
					} else {
						ibx_EndDate.setValue("");
						// return "";
					}
				}
				if (value.length < 6) {
					ibx_EndDate.setValue("");
					// return "";
				}
			};

			/**
			* 입력받은 str 의 왼쪽을 num만큼 chr로 채운다.
			* 
			* @date 2014. 12. 10.
			* @param <String> str 원본 문자열
			* @param <Number> num 채울 자리수
			* @param <String> chr 채울 문자
			* @example utilLib.lpad("1", 3, "0")
			* @return
			*/
			scwin.lpad = function(str, num, chr) {
				if (!str || !chr || str.length >= num) {
					return str;
				}

				var max = num - str.length;
				for ( var i = 0; i < max; i++) {
					str = chr + str;
				}

				return str;
			};

			/**
			* 년월 문자열 validate
			* @param <String> value yyyyMM
			* @return
			*/
			scwin.validateCalMonthStart = function(value) {
				if (value.length < 5) {
					comLib.alert($p, "날짜 데이터 자리수가 맞지 않습니다.", "scwin.validateCalMonthStartCallback");
				}

				if (parseInt(value.substr(4, 2)) > 12) {
					comLib.alert($p, "날짜 월 데이터가 맞지 않습니다.", "scwin.validateCalMonthStartCallback");
				}

				return value;
			};

			/**
			* 년월 문자열 validate
			* @param <String> value yyyyMM
			* @return
			*/
			scwin.validateCalMonthEnd = function(value) {
				if (value.length < 5) {
					comLib.alert($p, "날짜 데이터 자리수가 맞지 않습니다.", "scwin.validateCalMonthEndCallback");
				}

				if (parseInt(value.substr(4, 2)) > 12) {
					comLib.alert($p, "날짜 월 데이터가 맞지 않습니다.", "scwin.validateCalMonthEndCallback");
				}

				return value;
			};

			scwin.validateCalMonthStartCallback = function() {
				ibx_StrtDate.focus();
			};

			scwin.validateCalMonthEndCallback = function() {
				ibx_EndDate.focus();
			};

			udc_obj.getStrtDate = function() {
				if(ibx_StrtDate.getValue == "") {
					return null;
				} else {
					return ibx_StrtDate.getValue();
				}
			};
		
			udc_obj.getEndDate = function() {
				if (ibx_EndDate.getValue == "") {
					return null;
				} else {
					return ibx_EndDate.getValue();
				}
			};

			udc_obj.setStrtDate = function(strtDate) {
				ibx_StrtDate.setValue(strtDate);
			};

			udc_obj.setEndDate = function(endDate) {
				ibx_EndDate.setValue(endDate);
			};
			
			udc_obj.focusStrtDate = function(endDate) {
				ibx_StrtDate.focus();
			};	
			
			udc_obj.focusEndDate = function(endDate) {
				ibx_EndDate.focus();
			};

			// 초기 실행함수 수행
			this.initPeriodMonthCalendar();

			]]></script>
			<w2:style type="text/css"><![CDATA[ ]]></w2:style>
		</xf:group>
	</body>
</html>