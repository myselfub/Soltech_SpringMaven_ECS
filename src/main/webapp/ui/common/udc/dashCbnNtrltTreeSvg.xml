		<xf:group class="dash-cbn-ntrlt-tree" tagname="svg" pluginName="dash_cbn_ntrlt_tree">
			<script ev:event="oncreated(options)" type="text/javascript"><![CDATA[
				/**
				 * //property handling
				 * $w.log("id:" + options.id);
				 * $w.log("style:" + options.style);
				 * $w.log("class:" + options.class);
				 * $w.log("ref:" + options.ref);
				 *
				 * //event trigger
				*/
				// 초기 수행함수 
				this.initDashCbnNtrltTree = function() {
					// 기본 설정
					var dashCbnNtrltTreeClipPathUrl1 = "url(#" + grpDashCbnNtrltTreeClipPath1.getID() + ")";
					var dashCbnNtrltTreeClipPathUrl2 = "url(#" + grpDashCbnNtrltTreeClipPath2.getID() + ")";

					document.getElementById(grpClipPath1.getID()).setAttribute("clip-path", dashCbnNtrltTreeClipPathUrl1);
					document.getElementById(grpClipPath2.getID()).setAttribute("clip-path", dashCbnNtrltTreeClipPathUrl2);
				};
				// 탄소중립현황 이미지 크기 조정 함수
				this.setImageSize = function(bSize) {
					var cbnNtrlt = document.querySelector(".dash-con-box-pc .dash-box-con-cbn-ntrlt");
					var tree = cbnNtrlt.querySelector(".dash-cbn-ntrlt-tree .dash-cbn-ntrlt-tree");
					var factory = cbnNtrlt.querySelector(".dash-cbn-ntrlt-factory .dash-cbn-ntrlt-factory");

					if (bSize == "S") {
						tree.classList.remove("dash-cbn-ntrlt-tree-big");
						factory.classList.remove("dash-cbn-ntrlt-factory-small");
						tree.classList.add("dash-cbn-ntrlt-tree-small");
						factory.classList.add("dash-cbn-ntrlt-factory-big");
					} else if (bSize == "B") {
						tree.classList.remove("dash-cbn-ntrlt-tree-small");
						factory.classList.remove("dash-cbn-ntrlt-factory-big");
						tree.classList.add("dash-cbn-ntrlt-tree-big");
						factory.classList.add("dash-cbn-ntrlt-factory-small");
					} else if (bSize == "N" || bSize == "undefind") {
						tree.classList.remove("dash-cbn-ntrlt-tree-small");
						factory.classList.remove("dash-cbn-ntrlt-factory-big");
						tree.classList.remove("dash-cbn-ntrlt-tree-big");
						factory.classList.remove("dash-cbn-ntrlt-factory-small");
						tree.classList.add("dash-cbn-ntrlt-tree");
						factory.classList.add("dash-cbn-ntrlt-factory");
					}
				};

				// 초기 실행함수 수행
				this.initDashCbnNtrltTree();
		]]></script>
