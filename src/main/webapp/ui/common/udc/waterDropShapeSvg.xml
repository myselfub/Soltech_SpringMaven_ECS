		<xf:group class="water-drop-shape" tagname="svg" pluginName="water_drop_shape">
			<script ev:event="oncreated(options)" type="text/javascript"><![CDATA[
				/**
				 * //property handling
				 * $w.log("id:" + options.id);
				 * $w.log("style:" + options.style);
				 * $w.log("class:" + options.class);
				 * $w.log("ref:" + options.ref);
				 *
				 * //event trigger
				*/
				// 초기 수행함수 
				this.initWaterDropShape = function() {
					// fill 설정
					var fillTop = "";
					var fillBottom = "";
					if (options.fill && options.fill != "") {
						fillTop = options.fill;
						fillBottom = options.fill;
						fillLine = options.fill;
					} else {
						fillTop = "#FAFAFA";
						//fillBottom = "#79A7ED";
						fillBottom = "var(--dash-water-drop-shape-back-color)";
						fillLine = "#D4D4DA"
					}
					document.getElementById(grpTopShapeFill.getID()).setAttribute("fill", fillTop);
					document.getElementById(grpBottomShapeFill.getID()).setAttribute("fill", fillBottom);

					// stroke 설정
					var strokeLine = "";
					if (options.stroke && options.stroke != "") {
						strokeLine = options.fill;
					} else {
						strokeLine = "#D4D4DA"
					}
					document.getElementById(grpLineShapeStroke.getID()).setAttribute("stroke", strokeLine);

					// filter 설정
					var filterTop = "";
					var filterBottom = "";
					if (options.filter && options.filter != "") {
						filterTop = options.filter;
						filterBottom = options.filter;
					} else {
						filterTop = "url(#" + grpTopShapeShadow.getID() + ")";
						filterBottom = "url(#" + grpBottomShapeShadow.getID() + ")";
					}
					document.getElementById(grpTopShapeFilter.getID()).setAttribute("filter", filterTop);
					//document.getElementById(grpBottomShapeFilter.getID()).setAttribute("filter", filterBottom);
				};

				// 초기 실행함수 수행
				this.initWaterDropShape();
				]]></script>
