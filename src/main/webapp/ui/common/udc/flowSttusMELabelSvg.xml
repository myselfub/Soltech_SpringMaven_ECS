				*/

				// 초기 수행함수 
				this.initFlowSttusLabel = function() {
					var labelBackUrl = "url(#" + radialGradient.getID() + ")";
					document.getElementById(flowLabel.getID()).setAttribute("fill", labelBackUrl);

					var titleClass = document.querySelectorAll(".label-title-text-me-wrap");
					var textClass = document.querySelectorAll(".label-text-me-wrap");

					// 타이틀 라벨 text 설정 
					titleClass[0].innerHTML = "<tspan x=50 y=70 class=>폐기</tspan>" + "<tspan x=50 y=130 class=>수립</tspan>";
					titleClass[1].innerHTML = "<tspan x=50 y=70 class=>폐기</tspan>" + "<tspan x=50 y=130 class=>진행</tspan>";
					titleClass[2].innerHTML = "<tspan x=50 y=70 class=>폐기</tspan>" + "<tspan x=50 y=130 class=>진행</tspan>";
					titleClass[3].innerHTML = "<tspan x=50 y=70 class=>폐기</tspan>" + "<tspan x=50 y=130 class=>완료</tspan>";

					// 서브 타이틀 라벨 text 설정 
					textClass[0].innerHTML = "<tspan x=350 y=102>사업시행방침</tspan>";
					textClass[1].innerHTML = "<tspan x=350 y=102>발주및계약</tspan>";
					textClass[2].innerHTML = "<tspan x=350 y=102>공사시행</tspan>";
					textClass[3].innerHTML = "<tspan x=350 y=102>사업준공</tspan>";
				};

				// 초기 실행함수 수행
				this.initFlowSttusLabel();
]]></script>
