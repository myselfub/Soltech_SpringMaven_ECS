		<xf:group class="gb_udc_cal year" id="" style="" pluginName="year_calendar">

			<w2:style type="text/css"><![CDATA[ ]]></w2:style>
			<script ev:event="oncreated(options)" type="text/javascript"><![CDATA[
			/**
			* //property handling
			* $w.log("id:" + options.id);
			* $w.log("date:" + options.date);
			* $w.log("ref:" + options.ref);
			*
			* //event trigger
			* udc_obj.trigger("onBtnCalendarClick"); 
			*/

			// 초기 수행함수 
			this.initYearCalendar = function() {
				tbx_Year.hide();
				this.today = "";
				this.selectedDate = "";

				var tmpDate = new Date();
				var year = tmpDate.getFullYear();

				year = year + "";
				year = year.substr(0, 3) + "0";

				var startYear = parseInt(year);
				var endYear = parseInt(year) + 9;

				tbx_Year.setValue(startYear);
				tbx_Year_Label.setValue(startYear + "~" + endYear);

				// ref 설정
				if (options.ref != "") {
					ibx_Date.setRef(options.ref);
				}
				// udc의 초기 설정값
				if (ibx_Date.getValue() == "" && options.date != undefined) {
					ibx_Date.setValue(options.date);
				}
				this.changeYear(startYear);
			};

			this.showYearCalendar = function() {
				this.selectedDate = ibx_Date.getValue();

				// if (this.selectedDate.length >= 4) {
					// this.changeYear(this.selectedDate);
				// }

				if (div_Year.getStyle( "display") == "none") {
					div_Year.setStyle( "display", "");
				} else {
					div_Year.setStyle( "display", "none");
				}
			};

			// 시작 년도가 변경된 경우
			this.changeYear = function(strDate) {
				tbx_Year.setValue(strDate);

				var startYear = parseInt(strDate);
				var endYear = parseInt(strDate) + 9;

				tbx_Year.setValue(startYear);
				tbx_Year_Label.setValue(startYear + "~" + endYear);

				span_Year99.setValue(startYear - 1);

				for (var i = 0; i <= 10; i++) {
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);
					eval("span_Year" + month).setValue(startYear);
					eval("btn_Year" + month).removeClass("selected");

					if (eval("span_Year" + month).getLabel() == this.selectedDate) {
						eval("btn_Year" + month).addClass("selected");
					}
					startYear++;
				}
			};

			// 년도클릭시
			this.clickYears = function(strYear) {
				eval("btn_Year99").removeClass("selected");
				for (var i = 0; i <= 10; i++) {
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);
					eval("btn_Year" + month).removeClass("selected");
				}

				eval("btn_Year" + strYear).addClass("selected");

				this.selectedDate = eval("span_Year" + strYear).getLabel();

				udc_obj.confirmYear();
			};

			// 년도클릭시
			this.onYears = function(strYear) {
				for(var i = 0; i <= 10; i++) {
					var month = "00" + i;
					month = month.substr(month.length - 2, 2);
					eval("btn_Year" + month).removeClass("selected");

					if (eval("span_Year" + month).getLabel() == strYear) {
						eval("btn_Year" + month).addClass("selected");
					}
				}
				this.selectedDate = strYear;
			};

			//확인 버튼 클릭시 
			this.confirmYear = function() {
				ibx_Date.setValue(this.selectedDate + "");

				div_Year.setStyle("display", "none");
			};

			udc_obj.getDate = function() {
				if(ibx_Date.getValue() == "") {
					return null;
				} else {
					return ibx_Date.getValue();
				}
			};

			udc_obj.setDate = function(strDate) {
				ibx_Date.setValue(strDate);
			};

			//초기 실행함수 수행
			this.initYearCalendar();

			]]>
			</script>
