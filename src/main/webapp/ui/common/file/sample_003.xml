    	<script lazy="false" type="text/javascript"><![CDATA[
        //화면 오픈
       scwin.initScreen = function() {

        };
        
        /**
		 * 게시물을  조회한다.
		 * @param 검색조건
		 * @return  
		 */
		scwin.btnSearch_onclick = function() {
			scwin.searchNttMt();
		};
		scwin.searchNttMt = function() {
			var requestData = {};
				 requestData.data = {"nttSj" : ibxSearchNttSj.getValue()};
			var option = {action : "sc/sample/searchNttMt.do"
			               , reqData : requestData
			               , resData : dltNttList
			               , success : "scwin.searchNttMtCallback"
			               , isShowMeg : false
			                 };			
			ajaxLib.executeAjax($p, option);	
		};
        
        
        
       	/**
		 * 게시물 조회후 콜백 로직을 수행한다.
		 * @param resBody java단에서 넘겨 받은 값
		 * @return 
		 */
		scwin.searchNttMtCallback = function(resBody) {
		 	//alert ( "처리되었습니다.");
			//console.log ( resBody.data.nttCn );
		};	
		
		
		/**
		 * grid 클릭
		 */
        scwin.grdBbs_onrowindexchange = function(row,oldRow) {
			dmaNttMt.set( "ctgId" ,  dltNttList.getCellData( row , "ctgId" ) );
			dmaNttMt.set("sysSeCd", dltNttList.getCellData( row , "sysSeCd" ) );
			dmaNttMt.set("nttSj", dltNttList.getCellData( row , "nttSj" ) );
			dmaNttMt.set("nttCn", dltNttList.getCellData( row , "nttCn" ) );
			dmaNttMt.set("orginlFileNm", dltNttList.getCellData( row , "orginlFileNm" ) );
			var requestData = {};
				 requestData.dmaFileBasic = {"atchFileId" : dltNttList.getCellData( row , "atchFileId" )};
			var option = {action : "sc/file/fileList.do"
			               , reqData : requestData
			               , resData : dltMultiFileDataList
			               , success : "scwin.searchNttMtCallback"
			               , isShowMeg : false
			                 };			
			ajaxLib.executeAjax($p, option);	
		};
		
		/**
		 * 조회 콜백 함수
		 * @param
		 * @return
		 */
		scwin.searchNttMtCallback = function(resBody) {
			for ( var idx=0; idx<dltMultiFileDataList.getRowCount(); idx++) {
				dltMultiFileDataList.setCellData( idx , "name" , dltMultiFileDataList.getCellData( idx , "orginlFileNm" ) );
				dltMultiFileDataList.setCellData( idx , "displaySize" , dltMultiFileDataList.getCellData( idx , "fileSize" ) );
			}
		};
		
		/**
		 * 신규버튼 클릭
		 * @param
		 * @return
		 */
		scwin.btnAdd_onclick = function() {
			formReset();
		};
	
        /**********************************************************
        첨부파일 처리
        **********************************************************/
        /**
         * 첨부파일 선택이후 호출되는 콜백함수
         * @param  mpdMultiAtchFile.getFileInfos() 선택된 파일정보 
         * @return
         */
        function multiSelectCallback() {
        	//공통제공 함수호출
        	fileLib.multiSelectCallback(mpdMultiAtchFile, dltMultiFileDataList);
        };
        
        /**
         * 등록하고자 선택된 첨부파일 삭제처리(단, 저장전에만 가능함)
         * @param
         * @return
         */
       scwin.btnDelMultiFileonclick = function() {
			fileLib.multiDeleteFileList(grdMultiFile, mpdMultiAtchFile, dltMultiFileDataList, dltFile);
		};
		
        /**
         * 파일 임시저장(업로드) 이후 호출되는 콜백함수
         * @param data 업로드된 파일정보(원본파일명, 임시저장소 저장파일명, 파일사이즈)
         * @return 
         */
		scwin.mpdMultiAtchFile_ondone = function(data) {
			//첨부파일정보 셋팅
			fileLib.dataListSetting(dltFile, data);
			comLib.confirm($p, utilLib.getMessage("SC.INFO.00321"), "scwin.saveConfirmCallback");
		};
		
		/**
		 * 프로그래스바를 상태, 프로그래스바 사용시 필요함.
		 * @param info 파일전송상태값
		 * @return
		 */
		scwin.mpdMultiAtchFile_onprogress = function(info) {
			var rowidx = dltMultiFileDataList.getMatchedIndex("name", info.fileName);

			$("td[colindex='3']:eq("+rowidx+") .w2grid_input").text(info.percentData+"%");
			$("td[colindex='3']:eq("+rowidx+") .w2grid_input").css("width", info.percentData+"%");
		};
		
        /**
         *저장버튼 클릭
         * @param
         * @return 
         */
		scwin.btnSave_onclick = function() {
			// 입력값 셋팅
			dmaNttMt.set( "ctgId" , ibxCtg.getValue() );
			dmaNttMt.set( "sysSeCd", ibxSysSeCd.getValue() );
			dmaNttMt.set( "nttSj",  ibxNttSj.getValue() );
			dmaNttMt.set( "nttCn", txaNttCn.getValue() );
			
			//첨부파일정보가 있는 경우는 파일전송처리부터 실해됨
			//첨부파일이 없는 경우는 데이터만 저장
			if ( dltMultiFileDataList.getRowCount() > 0 ) {
				mpdMultiAtchFile.startUpload();
			} else {  
				comLib.confirm($p, utilLib.getMessage("SC.INFO.00321"), "scwin.saveConfirmCallback");
			}
		};
	
	    /**
		 * 저장처리
		 * @param
		 * @return 
		 */
		scwin.saveConfirmCallback = function() {
			var requestData = {};
			requestData.data = dmaNttMt.getJSON();
			requestData.data1 = dltFile.getAllJSON();
			
			var option = {action : "sc/sample/saveNttMt.do"
			               , reqData : requestData
			               , resData : dltNttList
			               , success : "scwin.saveCallback"
			               , isShowMeg : false
				            };			
			ajaxLib.executeAjax($p, option);
		};
		
		/**
		 * 저장후 콜백
		 * @param resBody (서비스단에서 받은 데이터)
		 * @return 
		 */
		scwin.saveCallback = function(resBody) {
//			comLib.alert($p, utilLib.getMessage(resBody.message.code_name));
			comLib.alert($p, resBody.message.code_name);
			formReset();
			scwin.searchNttMt();
		};
	
		/**
		 * 입력폼 초기화
		 * @param 
		 * @return 
		 */
		function formReset() {
			dmaNttMt.undo();
			dltFile.removeAll();
			dltMultiFileDataList.removeAll();
			ibxCtg.setValue("");
			ibxSysSeCd.setValue("");
			ibxNttSj.setValue("");
			txaNttCn.setValue("");
		};	
	
		/**
		 * 첨부파일 다운로드
		 * @param event
		 * @return 첨부파일
		 */
		scwin.grdMultiFile_oncellclick = function(row,col) {
			var row = grdMultiFile.getFocusedRowIndex();
			var atchFileId = dltFile.getCellData( row, "atchFileId" );       	//첨부파일 ID
			var fileSn = dltFile.getCellData( row, "fileSn" );       	//첨부파일 ID
			var filePath = dltFile.getCellData(row, "fileSavePath");				//서버에 저장된 파일 경로
			var saveFileName = dltFile.getCellData( row , "saveFileNm" );			//서버에 저장된 파일명
			var fileName = dltFile.getCellData(row, "orginlFileNm");		//저장할 파일명

			if (atchFileId != null && atchFileId != '' ) {
				// filePath : 서버에 저장된 파일 경로
				// saveFileName : 서버에 저장된 파일명
				// fileName : 원본파일명
				var sendUrl = filePath + "/" + saveFileName;
				console.log ( sendUrl );
				fileLib.fileDownload(sendUrl, fileName);
			}
		};
	
		/**
		 * SAP용 팝업 호출
		 * @param 없음.
		 * @return 없음.
		 */
/*	
		scwin.btn_SapPopup_onclick = function() {
			var options = {
					title : "SAP용 업로드", width : 800, height : 420, 
					popupParam : { closeCallbackFncName : "scwin.sapFileUploadCallback" }
				};
			comLib.openPopup($p, "sapFileUpload", "/ui/common/file/sample_002.xml", options);
		};
*/
	]]></script>
