				mpd_multiAtchFile.startUpload();
			};
			
			
			scwin.mpd_multiAtchFile_onprogress = function(info) {
				var rowidx = dlt_FileDataList.getMatchedIndex("name", info.fileName);
				
				$p.$("#grd_MultiFile td[colindex='3']:eq("+rowidx+") .w2grid_input").text(info.percentData+"%");
				$p.$("#grd_MultiFile td[colindex='3']:eq("+rowidx+") .w2grid_input").css("width", info.percentData+"%");
				
				console.log ("rowidx : " + rowidx + " // "  + info.percentData + "%");
				
//				grd_MultiFile.setCellBackgroundColor( rowidx , "Status" , "red" );
			};
			
			scwin.mpd_multiAtchFile_ondone = function(data) {
//				alert ( JSON.stringify(data) );
				alert ( "임시저장이 되었습니다.");
				
			};
	]]>
