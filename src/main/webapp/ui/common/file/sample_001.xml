        //화면 오픈
       scwin.initScreen = function() {

        };
        
        /**
		 * 게시물을  조회한다.
		 * @param 검색조건
		 * @return  검색결과
		 */
		scwin.btnSearch_onclick = function() {
			scwin.searchNttMt();
		};
		scwin.searchNttMt = function() {
			var requestData = {};
				 requestData.data = {"nttSj" : ibxSearchNttSj.getValue()};
			var option = {action : "sc/sample/searchNttMt.do"
			               , reqData : requestData
			               , resData : dltNttList
			               , success : "scwin.searchNttMtCallback"
			               , isShowMeg : false
			                 };			
			ajaxLib.executeAjax($p, option);	
		};
        
       	/**
		 * 게시물 조회후 콜백 로직을 수행한다.
		 * @param resBody java단에서 넘겨받은 결과값
		 * @return 
		 */
		scwin.searchNttMtCallback = function(resBody) {
		 	//alert ( "처리되었습니다.");
			//console.log ( resBody.data.nttCn );
		};	
		
		
		/**
		 * 그리드 클릭
		 * @param
		 * @return
		 */
        scwin.grdBbs_onrowindexchange = function(row,oldRow) {
			dmaNttMt.set( "ctgId" ,  dltNttList.getCellData( row , "ctgId" ) );
			dmaNttMt.set("sysSeCd", dltNttList.getCellData( row , "sysSeCd" ) );
			dmaNttMt.set("nttSj", dltNttList.getCellData( row , "nttSj" ) );
			dmaNttMt.set("nttCn", dltNttList.getCellData( row , "nttCn" ) );
			dmaNttMt.set("orginlFileNm", dltNttList.getCellData( row , "orginlFileNm" ) );
		};
		
		/**
		 * 신규버튼클릭
		 * @param
		 * @return
		 */
		scwin.btnAdd_onclick = function() {
			formReset();          //입력폼값 초기화
		};
	
        /**********************************************************
        첨부파일 처리
        **********************************************************/
        /**
         * 첨부파일 선택이후 콜백
         * @param
         * @return
         */
        function singlSelectCallback() {
        	var fileInfos = mpdSinglFile.getFileInfos();
        	ibxAtchFile.setValue(fileInfos[0].name);
        };
        
        /**
         * 등록하고자 선택된 첨부파일 삭제처리(단, 저장전에만 가능함)
         * @param
         * @return
         */
        scwin.btnDelSinglFile_onclick = function() {
			ibxAtchFile.setValue("");
			mpdSinglFile.removeAllFiles();
		};
		
		
		
        /**
         * 첨부 파일 임시저장후 콜백(전송)
         * @param
         * @return
         */
		scwin.mpdSinglFile_ondone = function(data) {
			//첨부파일정보 셋팅
			fileLib.dataListSetting(dltFile, data);
//			comLib.confirm($p, utilLib.getMessage("게시물을 저장하시겠습니까?"), "scwin.saveConfirmCallback");
			comLib.confirm($p, "게시물을 저장하시겠습니까?", "scwin.saveConfirmCallback");
		};
		
		/**
		 * 화면단 프로그래스바를 사용할 경우 사용
		 * @param info 서버로 업로드시 파일전송 상태값
		 * @return
		 */
		scwin.mpdSinglFile_onprogress = function(info) {
			var rowidx = fileDataList.getMatchedIndex("name", info.fileName);

			ibxBigFileStatus.setValue( info.percentData + "%" );
			ibxBigFileStatus.setStyle("display", "block");
			ibxBigFileStatus.setStyle("background","#ffcc00");
			ibxBigFileStatus.setStyle("background-repeat","repeat-x");
			ibxBigFileStatus.setStyle("background-position","left top");
			ibxBigFileStatus.setStyle("background-image","url('/scm/resources/images/common/pro.png')");
			ibxBigFileStatus.setStyle( "width" , info.percentData + "%" );
		};
		
        /**
         * 저장버튼 클릭
         * @param
         * @return
         */
		scwin.btnSave_onclick = function() {
			// 입력값 셋팅 (입력 컨포넌트들을 dataCollection에 매핑시 필요없음)
			dmaNttMt.set( "ctgId" , ibxCtg.getValue() );
			dmaNttMt.set( "sysSeCd", ibxSysSeCd.getValue() );
			dmaNttMt.set( "nttSj",  ibxNttSj.getValue() );
			dmaNttMt.set( "nttCn", txaNttCn.getValue() );
			
			// 첨부파일이 있는 경우
			if ( ibxAtchFile.getValue() != '' ) {
				mpdSinglFile.startUpload();
			} else { //첨부파일이 없는 경우
				comLib.confirm($p, utilLib.getMessage("SC.INFO.00321"), "scwin.saveConfirmCallback");
			}
		};
	
	    /**
		 * 실제 저장처리는 하는 함수
		 * @param
		 * @return
		 */
		scwin.saveConfirmCallback = function() {
			var requestData = {};
			requestData.data = dmaNttMt.getJSON();
			requestData.data1 = dltFile.getAllJSON();
			
			var option = {action : "sc/sample/saveNttMt.do"
			               , reqData : requestData
			               , resData : dltNttList
			               , success : "scwin.saveCallback"
			               , isShowMeg : false
				            };			
			ajaxLib.executeAjax($p, option);
		};
		
		/**
		 * 저장후 콜백
		 * @param resBody (서비스단에서 받은 데이터)
		 * @return 
		 */
		scwin.saveCallback = function(resBody) {
//			comLib.alert($p, utilLib.getMessage(resBody.message.code_name));
			comLib.alert($p, resBody.message.code_name);
			formReset();
			scwin.searchNttMt();
		};
	
		/**
		 * 입력폼 초기화
		 * @param 
		 * @return 
		 */
		function formReset() {
			dmaNttMt.undo();
			dltFile.removeAll();
			ibxAtchFile.setValue( "" );
			ibxCtg.setValue("");
			ibxSysSeCd.setValue("");
			ibxNttSj.setValue("");
			txaNttCn.setValue("");
		};	
	
		/**
		 * 첨부파일 다운로드
		 * @param event
		 * @return 첨부파일
		 */
		scwin.ibxAtchFile_onclick = function(e) {
			var row = grdBbs.getFocusedRowIndex();
			var atchFileId = dltNttList.getCellData( row, "atchFileId" );       	//첨부파일 ID
			var fileSn = dltNttList.getCellData( row, "fileSn" );       	//첨부파일 ID
			var filePath = dltNttList.getCellData(row, "fileSavePath");				//서버에 저장된 파일 경로
			var saveFileName = dltNttList.getCellData( row , "saveFileNm" );			//서버에 저장된 파일명
			var fileName = dltNttList.getCellData(row, "orginlFileNm");		//저장할 파일명

			if (atchFileId != null && atchFileId != '' ) {
				// filePath : 서버에 저장된 파일 경로
				// saveFileName : 서버에 저장된 파일명
				// fileName : 원본파일명
				var sendUrl = filePath + "/" + saveFileName;
				fileLib.fileDownload(sendUrl, fileName);
			}
		};
	
		/**
		 * SAP용 팝업 호출 (임시)
		 * @param 없음.
		 * @return 없음.
		 */
		scwin.btnSapPopup_onclick = function() {
			var options = {
					title : "문서관리(SAP)", width : 800, height : 670, 
					popupParam : { closeCallbackFncName : "scwin.sapFileUploadCallback" }
				};
			comLib.openPopup($p, "sapFile", "/ui/scm/sc/docMng/SCMSC40000003.xml&usrId=100001&sysSeCd=SCM&jobSeCd=SC&tCode=12345&objectKey=11111&popupId=sapFile", options);
		};
	]]></script>
