				</w2:dataMap>
				<w2:dataList id="dltPlanCnstrcRsrnList" baseNode="list" repeatNode="map" saveRemovedData="true">
					<w2:columnInfo>
						<!-- id명 임시 지정 (리스트 전체) -->
						<w2:column id="chk" dataType="text" name="선택"></w2:column>
						<w2:column id="num" dataType="number" name="No"></w2:column>
						<w2:column id="dmtNum" dataType="number" name="문서번호"></w2:column>
						<w2:column id="dmtNm" dataType="text" name="문서명"></w2:column>
						<w2:column id="drftDept" dataType="text" name="기안부서"></w2:column>
						<w2:column id="drafter" dataType="text" name="기안자"></w2:column>
						<w2:column id="drftDt" dataType="text" name="기안일시"></w2:column>
					</w2:columnInfo>
					<w2:data use="false"></w2:data>
				</w2:dataList>
			</w2:dataCollection>
			<w2:workflowCollection></w2:workflowCollection>
		</xf:model>
		<script lazy="false" type="text/javascript"><![CDATA[
