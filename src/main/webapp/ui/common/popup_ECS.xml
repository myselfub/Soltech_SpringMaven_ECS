	/**
	 * 화면 초기화에 필요한 로직을 수행한다.
	 * @param
	 * @return
	 */
	scwin.initScreen = function() {
		//화면초기화 공통 함수 호출
		comLib.initForm($p, "ECSPB100000");
		//데이터 조회
		scwin.btnInqire_onclick();
		
		dmaSearchParam.set("strtDt", utilLib.addDay(utilLib.getCurrentDate("yyyyMMdd"), -7));
		dmaSearchParam.set("endDt", utilLib.getCurrentDate());
	};

	/**
	 * 조회조건에 맞게 data를 조회한다.
	 * @param
	 * @return
	 */
	scwin.btnInqire_onclick = function() {
		var searchParam = dmaSearchParam.getJSON();
		var strtDate = dmaSearchParam.get("strtDt");
		var endDate = dmaSearchParam.get("endDt");
		var params = "?strtDt=strtDate&endDt=endDate&dmtTitle=ALL&drafter=ALL";
		
		if (utilLib.minusDates(strtDate, endDate) > 31 ? true : false) {
			alert("조회기간은 31일이 넘어갈 수 없습니다. 다시 설정해 주세요.");
			return;
		}
		
		/** 추후 action URL 수정 해야함 _230612 */
		var option = {
			action : "ec/energyacmsltmng/retrieveReccdm.do",
			method : "get",
			resData : dltPlanCnstrcRsrnList,
			success : "scwin.inqireCallback",
			isShowMeg : false
		};
		ajaxLib.executeAjax($p, option);
	};

	/**
	 * 조회 CallBack 실행한다.   
	 * @param <Object> resBody
	 * @return
	 */
	scwin.inqireCallback = function(resBody) {
		if (resBody.message.code == "success") {
			txtCnt.setValue(dltPlanCnstrcRsrnList.getRowCount());

			// 조회된 값에 권한ID가 비어있지 않으면 읽기 속성으로 비어 있으면 쓰기 로 설정 변경 
			for (var i = 0; i < dltPlanCnstrcRsrnList.getRowCount(); i++) {
				if (i < 7) {
					grdPlanCnstrcRsrnList.setRowReadOnly(i, true);
				} else {
					grdPlanCnstrcRsrnList.setCellReadOnly(i, "btnSeq", true);
				}
			}
		} else {
			comLib.alert($p, "fail");
		}
	};
]]></script>
